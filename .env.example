# =============================================================
# dblumi — Configuration
# Copiez ce fichier en .env et remplissez les valeurs
# =============================================================

# ------- OBLIGATOIRES ----------------------------------------
# Clé AES-256 (32 bytes hex) — générez avec:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DBLUMI_ENCRYPTION_KEY=

# Chemin du fichier SQLite (interne à dblumi)
DATABASE_PATH=./data/dblumi.db

# Secret JWT (minimum 32 caractères)
JWT_SECRET=

# URL publique de l'instance (sans slash final)
BASE_URL=http://localhost:3000

# ------- OPTIONNELLES ----------------------------------------
PORT=3000
LOG_LEVEL=info
DBLUMI_TELEMETRY=false

# Clé Claude partagée (optionnel — les utilisateurs peuvent apporter la leur)
ANTHROPIC_API_KEY=

# OAuth GitHub (optionnel)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# OAuth Google (optionnel)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
