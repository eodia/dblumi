# ── Core (required) ──
JWT_SECRET=change-me-to-a-long-random-string-min-32-chars
DBLUMI_ENCRYPTION_KEY=change-me-64-hex-chars-representing-32-bytes

# ── Server ──
# DATABASE_PATH=./data/dblumi.db
# BASE_URL=http://localhost:3000
# PORT=3000

# ── OAuth providers (optional) ──
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ── Keycloak SSO (optional) ──
# KEYCLOAK_ISSUER=https://your-keycloak/realms/your-realm
# KEYCLOAK_CLIENT_ID=dblumi
# KEYCLOAK_CLIENT_SECRET=

# ── SMTP — password reset emails (optional) ──
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@your-domain.com

# ── AI Copilot (one provider at a time) ──
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_DEPLOYMENT=
