# ── Obligatoire ──────────────────────────────────────────────────────────────

# Clé de chiffrement AES-256 (32 octets en hex = 64 caractères)
# Générer : openssl rand -hex 32
DBLUMI_ENCRYPTION_KEY=

# Secret JWT (min 32 caractères)
# Générer : openssl rand -base64 32
JWT_SECRET=

# URL publique de l'application
BASE_URL=http://localhost:3000


# ── Copilot IA — un seul provider à la fois ─────────────────────────────────
# Priorité : OpenAI > Azure OpenAI > Anthropic

# Anthropic (Claude) — BYOK par utilisateur possible même sans clé instance
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=                        # défaut : claude-sonnet-4-20250514

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=                           # défaut : gpt-4o

# Azure OpenAI
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=                  # ex: https://my-resource.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=               # ex: gpt-4o (nom du déploiement)


# ── OAuth SSO ────────────────────────────────────────────────────────────────

# GitHub OAuth App
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth App
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Keycloak / OIDC d'entreprise
KEYCLOAK_ISSUER=                        # ex: https://keycloak.example.com/realms/myrealm
KEYCLOAK_CLIENT_ID=
KEYCLOAK_CLIENT_SECRET=


# ── Optionnel ────────────────────────────────────────────────────────────────

# Chemin de la base de données SQLite
DATABASE_PATH=./data/dblumi.db

# Niveau de log : fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# Télémétrie anonyme (true/false)
DBLUMI_TELEMETRY=false
