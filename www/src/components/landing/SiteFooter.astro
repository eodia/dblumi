---
// www/src/components/landing/SiteFooter.astro
import { strings, type Lang } from '../../content/landing-strings';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = strings[lang].footer;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<footer class="db-footer">
  <div class="db-footer-inner">
    <div class="db-footer-grid">
      <div class="db-footer-brand">
        <a href={lang === 'fr' ? `${base}/fr/` : `${base}/`} class="db-footer-logo" aria-label="dblumi home">
          <img src={`${base}/logo-dblumi.svg`} alt="dblumi" />
        </a>
      </div>
      {Object.entries(t.columns).map(([, col]) => (
        <div class="db-footer-col">
          <h4>{col.title}</h4>
          <ul>
            {col.links.map((link) => {
              const isExternal = link.href.startsWith('http') || link.href.startsWith('mailto:');
              const href = isExternal ? link.href : `${base}${link.href}`;
              return <li><a href={href}>{link.label}</a></li>;
            })}
          </ul>
        </div>
      ))}
    </div>
    <div class="db-footer-bar">
      <span>{t.copyright}</span>
      <div class="socials">
        <a href="https://github.com/eodia/dblumi" aria-label="GitHub">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
        </a>
        <a href="https://discord.gg/2uTk5X9B" aria-label="Discord">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.095 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.095 2.157 2.42 0 1.333-.947 2.418-2.157 2.418z"/></svg>
        </a>
      </div>
    </div>
  </div>
</footer>

<style>
  .db-footer {
    padding: 80px 40px 48px;
    background:
      radial-gradient(circle at 12% 0%, rgba(65, 205, 42, 0.10), transparent 45%),
      radial-gradient(circle at 88% 100%, rgba(65, 205, 42, 0.06), transparent 50%),
      linear-gradient(180deg, #0d0d0f 0%, #0a0a0b 100%);
    color: #9a9aa0;
    border-radius: 20px;
    margin-top: 48px;
    position: relative;
    overflow: hidden;
  }
  .db-footer::before {
    content: "";
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(65, 205, 42, 0.35), transparent);
    pointer-events: none;
  }
  .db-footer-inner {
    max-width: 1100px;
    margin: 0 auto;
    position: relative;
  }
  .db-footer-grid {
    display: grid;
    grid-template-columns: 1.4fr repeat(4, 1fr);
    gap: 32px;
    margin-bottom: 48px;
  }
  .db-footer-logo {
    display: inline-flex;
    align-items: center;
  }
  .db-footer-logo img {
    height: 32px;
    width: auto;
    display: block;
  }
  .db-footer-col h4 {
    font-size: 11px; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.1em;
    color: #e5e5ea;
    margin: 0 0 14px;
  }
  .db-footer-col ul {
    list-style: none;
    padding: 0; margin: 0;
    display: flex; flex-direction: column; gap: 8px;
  }
  .db-footer-col li a {
    font-size: 12.5px; color: #9a9aa0;
    transition: color 0.15s;
  }
  .db-footer-col li a:hover { color: #fff; }
  .db-footer-bar {
    padding-top: 28px;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    display: flex; align-items: center;
    font-size: 11.5px; color: #6b6b76;
  }
  .db-footer-bar .socials {
    margin-left: auto;
    display: flex; gap: 8px;
  }
  .db-footer-bar .socials a {
    width: 32px; height: 32px;
    display: inline-flex; align-items: center; justify-content: center;
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.06);
    color: #9a9aa0;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
  }
  .db-footer-bar .socials a:hover {
    color: #fff;
    background: rgba(65, 205, 42, 0.1);
    border-color: rgba(65, 205, 42, 0.3);
  }

  @media (max-width: 800px) {
    .db-footer-grid { grid-template-columns: 1fr 1fr; }
    .db-footer-brand { grid-column: 1 / -1; }
  }
</style>
