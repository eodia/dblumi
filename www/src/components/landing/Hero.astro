---
import { strings, type Lang } from '../../content/landing-strings';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = strings[lang].hero;
const m = t.mockup;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<section class="db-hero">
  <!-- LEFT TEXT COLUMN -->
  <div class="db-hero-text">
    <div class="badge">
      <span class="dot"></span>
      {t.badge}
    </div>
    <h1>
      <span class="l">{t.headline.line1}</span>
      <span class="l">{t.headline.line2}</span>
      <span class="l">{t.headline.line3}</span>
      <span class="l"><span class="kalam brand">{t.headline.accent}</span></span>
    </h1>
    <p class="sub">{t.lead}</p>
    <div class="btns">
      <a href={lang === 'fr' ? `${base}/fr/guides/installation/` : `${base}/guides/installation/`} class="btn-p">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        {t.ctaPrimary}
      </a>
      <a href={lang === 'fr' ? `${base}/fr/demo/` : `${base}/demo/`} class="btn-s">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8"/></svg>
        {t.ctaSecondary}
      </a>
    </div>
  </div>

  <!-- RIGHT APP MOCKUP -->
  <div class="app-mock" id="db-hero-mock">
    <!-- Topbar -->
    <div class="topbar">
      <div class="wdots"><div class="d d1"></div><div class="d d2"></div><div class="d d3"></div></div>
    </div>

    <div class="body">
      <aside class="sidebar">
        <!-- Connection header -->
        <div class="conn-hdr">
          <span class="conn-dot"></span>
          <svg class="pg-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <ellipse cx="12" cy="5" rx="9" ry="3"/>
            <path d="M3 5v14c0 1.7 4 3 9 3s9-1.3 9-3V5"/>
            <path d="M3 12c0 1.7 4 3 9 3s9-1.3 9-3"/>
          </svg>
          <div class="conn-info">
            <div class="conn-top">
              <span class="conn-name">eodia</span>
              <span class="env-pill">{m.envProd}</span>
            </div>
            <div class="conn-host">@db.eodia.net</div>
          </div>
          <svg class="chev-switch" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="7 15 12 20 17 15"/><polyline points="7 9 12 4 17 9"/></svg>
        </div>

        <!-- Database selector -->
        <div class="db-selector">
          <svg class="db-ic" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5v14c0 1.7 4 3 9 3s9-1.3 9-3V5"/><path d="M3 12c0 1.7 4 3 9 3s9-1.3 9-3"/></svg>
          <span class="db-name">postgres</span>
          <svg class="chev" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
        </div>

        <!-- Navigation -->
        <nav class="sb-nav">
          <div class="nav-item">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
            {m.navProject}
          </div>
          <div class="nav-item" data-view="tables">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/><path d="M3 15h18"/><path d="M9 3v18"/></svg>
            {m.navTables}
          </div>
          <div class="nav-item active" data-view="sql">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="16" rx="2"/><path d="M7 9l3 3-3 3"/><path d="M13 15h4"/></svg>
            {m.navSqlEditor}
          </div>
        </nav>

        <!-- SQL Editor view: Saved queries -->
        <div class="sb-view sql-view active">
          <div class="sq-hdr">
            <span class="label">{m.savedQueriesLabel}</span>
            <svg class="plus" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          </div>
          <div class="sq-list">
            <div class="sq-item active">
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
              <span class="name">regions_by_revenue</span>
            </div>
            <div class="sq-item">
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
              <span class="name">churn_cohort</span>
            </div>
            <div class="sq-item">
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
              <span class="name">top_customers</span>
            </div>
            <div class="sq-item">
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
              <span class="name">daily_mrr</span>
            </div>
          </div>
        </div>

        <!-- Tables view: schema tree -->
        <div class="sb-view tables-view">
          <div class="search-row">
            <div class="search-input">
              <svg class="ic" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
              {m.filterTables}
            </div>
            <span class="refresh-btn">
              <svg class="ic" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
            </span>
          </div>
          <div class="section-hdr">
            <svg class="ic chev" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
            <svg class="ic" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="rgba(220,38,38,0.5)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v18"/><path d="M3 7.5h18"/><path d="M3 12h18"/><path d="M3 16.5h18"/><rect x="3" y="3" width="18" height="18" rx="2"/></svg>
            <span>{m.tableSectionLabel}</span>
            <span class="count">24</span>
            <span class="plus">
              <svg class="ic" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            </span>
          </div>
          <!-- orders — expanded with columns -->
          <div class="tbl-row is-table">
            <span class="chev-btn"><svg class="ic" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg></span>
            <div class="tbl-main">
              <svg class="ic ic-main" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v18"/><path d="M3 7.5h18"/><path d="M3 12h18"/><path d="M3 16.5h18"/><rect x="3" y="3" width="18" height="18" rx="2"/></svg>
              <span class="name">orders</span>
              <span class="cnt">12</span>
            </div>
          </div>
          <div class="tbl-cols">
            <div class="col-row">
              <svg class="ic ic-key" width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/></svg>
              <span class="cname">id</span><span class="type">uuid</span>
            </div>
            <div class="col-row">
              <svg class="ic ic-col" width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="9" y1="3" x2="9" y2="21"/><line x1="15" y1="3" x2="15" y2="21"/><rect x="3" y="3" width="18" height="18" rx="2"/></svg>
              <span class="cname">region</span><span class="type">text</span>
            </div>
            <div class="col-row">
              <svg class="ic ic-col" width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="9" y1="3" x2="9" y2="21"/><line x1="15" y1="3" x2="15" y2="21"/><rect x="3" y="3" width="18" height="18" rx="2"/></svg>
              <span class="cname">total</span><span class="type">numeric</span>
            </div>
            <div class="col-row">
              <svg class="ic ic-col" width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="9" y1="3" x2="9" y2="21"/><line x1="15" y1="3" x2="15" y2="21"/><rect x="3" y="3" width="18" height="18" rx="2"/></svg>
              <span class="cname">created_at</span><span class="type">timestamp</span>
            </div>
          </div>
          <!-- customers — collapsed -->
          <div class="tbl-row is-table">
            <span class="chev-btn"><svg class="ic" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg></span>
            <div class="tbl-main">
              <svg class="ic ic-main" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v18"/><path d="M3 7.5h18"/><path d="M3 12h18"/><path d="M3 16.5h18"/><rect x="3" y="3" width="18" height="18" rx="2"/></svg>
              <span class="name">customers</span><span class="cnt">8</span>
            </div>
          </div>
          <!-- products — collapsed -->
          <div class="tbl-row is-table">
            <span class="chev-btn"><svg class="ic" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg></span>
            <div class="tbl-main">
              <svg class="ic ic-main" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v18"/><path d="M3 7.5h18"/><path d="M3 12h18"/><path d="M3 16.5h18"/><rect x="3" y="3" width="18" height="18" rx="2"/></svg>
              <span class="name">products</span><span class="cnt">15</span>
            </div>
          </div>
          <!-- invoices — collapsed -->
          <div class="tbl-row is-table">
            <span class="chev-btn"><svg class="ic" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg></span>
            <div class="tbl-main">
              <svg class="ic ic-main" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v18"/><path d="M3 7.5h18"/><path d="M3 12h18"/><path d="M3 16.5h18"/><rect x="3" y="3" width="18" height="18" rx="2"/></svg>
              <span class="name">invoices</span><span class="cnt">9</span>
            </div>
          </div>
        </div>

        <div class="sb-spacer"></div>

        <!-- Account footer -->
        <div class="sb-account">
          <div class="avatar">M</div>
          <div class="acc-info">
            <div class="acc-name">{m.accountName}</div>
            <div class="acc-email">{m.accountEmail}</div>
          </div>
          <svg class="chev-switch" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="7 15 12 20 17 15"/><polyline points="7 9 12 4 17 9"/></svg>
        </div>
      </aside>

      <!-- Main column -->
      <div class="main-col">
        <div class="tabs-row">
          <div class="tab active">regions_by_revenue.sql <span class="close">×</span></div>
          <div class="tab">churn_cohort.sql <span class="close">×</span></div>
          <span class="newtab">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          </span>
          <div class="spacer"></div>
          <div class="actions">
            <button class="tab-btn">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
              {m.tabSave}
              <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="opacity:0.5"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <button class="tab-btn primary" id="btn-run">
              <svg class="play-icon" width="11" height="11" viewBox="0 0 24 24" fill="currentColor"><polygon points="6 4 20 12 6 20 6 4"/></svg>
              <span class="spinner"></span>
              {m.tabRun}
            </button>
            <button class="tab-btn copilot">{m.tabCopilot}</button>
          </div>
        </div>

        <div class="below-tabs">
          <div class="editor-area">
            <div class="editor" id="db-hero-editor">
              <div class="editor-empty" id="db-hero-editor-empty">// Start typing or ask the copilot…</div>
            </div>
            <div class="results-wrap" id="db-hero-results">
              <div class="results-toolbar">
                <span class="stats">
                  <svg class="check" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                  {m.statusRows}
                </span>
                <span class="ms">· {m.statusTime}</span>
                <span style="flex:1"></span>
                <span class="tool">
                  <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M7 12h10"/><path d="M10 18h4"/></svg>
                  {m.sort}
                </span>
                <span class="tool">
                  <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
                  {m.explain}
                </span>
              </div>
              <div class="results-table-wrap">
                <table class="results">
                  <thead>
                    <tr>
                      <th style="width:28px">#</th>
                      <th>region</th>
                      <th class="num">revenue</th>
                    </tr>
                  </thead>
                  <tbody>
                    <tr><td class="idx">1</td><td>North America</td><td class="num">1,245,320</td></tr>
                    <tr><td class="idx">2</td><td>Europe</td><td class="num">987,410</td></tr>
                    <tr><td class="idx">3</td><td>Asia Pacific</td><td class="num">754,192</td></tr>
                    <tr><td class="idx">4</td><td>Latin America</td><td class="num">412,876</td></tr>
                    <tr><td class="idx">5</td><td>Middle East</td><td class="num">298,540</td></tr>
                    <tr><td class="idx">6</td><td>Africa</td><td class="num">187,320</td></tr>
                    <tr><td class="idx">7</td><td>Oceania</td><td class="num">142,890</td></tr>
                    <tr><td class="idx">8</td><td>Caribbean</td><td class="num">98,720</td></tr>
                  </tbody>
                </table>
              </div>
              <div class="results-pagination">
                <span class="per">
                  {m.rowsPerPage}
                  <span class="pill">100 ▾</span>
                </span>
                <span class="sep">·</span>
                <span>{m.pageOf}</span>
                <span class="right">
                  <span class="nav">«</span>
                  <span class="nav">‹</span>
                  <span class="page active">1</span>
                  <span class="page">2</span>
                  <span class="page">3</span>
                  <span class="nav">›</span>
                  <span class="nav">»</span>
                </span>
              </div>
            </div>
          </div>

          <aside class="cop-panel">
            <div class="hdr">
              <svg class="spark" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" stroke="none" aria-hidden="true"><path d="M12 3 L13.6 10.4 L21 12 L13.6 13.6 L12 21 L10.4 13.6 L3 12 L10.4 10.4 Z"/></svg>
              <span class="title">{m.tabCopilot}</span>
              <span class="subtitle">{m.copilotSubtitle}</span>
              <span class="spacer"></span>
              <span class="close">×</span>
            </div>
            <div class="content">
              <div class="empty-state" id="db-hero-empty-state">
                <svg class="bot-icon" width="46" height="46" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M12 8V4H8"/>
                  <rect width="16" height="12" x="4" y="8" rx="2"/>
                  <path d="M2 14h2"/>
                  <path d="M20 14h2"/>
                  <path d="M15 13v2"/>
                  <path d="M9 13v2"/>
                </svg>
                <p class="prompt">{m.emptyPrompt}</p>
                <div class="pills">
                  <span class="pill">{m.pill1}</span>
                  <span class="pill">{m.pill2}</span>
                  <span class="pill">{m.pill3}</span>
                  <span class="pill">{m.pill4}</span>
                </div>
              </div>
              <div class="convo" id="db-hero-convo">
                <div class="user-msg" id="db-hero-user-msg"></div>
                <div class="typing" id="db-hero-typing"><span></span><span></span><span></span></div>
                <div class="ai-msg" id="db-hero-ai-msg">
                  <div class="bot-row"><span>✦</span> Suggestion</div>
                  {m.animAiIntro}
                </div>
              </div>
            </div>
            <div class="input-bar">
              <div class="input" id="db-hero-copilot-input" data-placeholder={m.inputPlaceholder}></div>
              <span class="send">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
              </span>
            </div>
          </aside>
        </div>
      </div>
    </div>

    <!-- Mouse cursor SVG (positioned + animated by Task 14 script) -->
    <svg class="mouse-cursor" id="db-hero-mouse" viewBox="0 0 24 24" fill="#fff" stroke="#0a0a0b" stroke-width="1.5" stroke-linejoin="round">
      <path d="M5 3 L5 17 L9 13 L12 20 L14 19 L11 12 L17 12 Z"/>
    </svg>
  </div>
</section>

<style>
  .db-hero {
    font-family: 'Inter', system-ui, sans-serif;
    background: #fff;
    padding: 96px 48px 56px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 0.85fr 1.25fr;
    gap: 52px;
    align-items: center;
    max-width: 1400px;
  }

  .db-hero .badge {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 6px 14px; border-radius: 100px;
    background: rgba(65, 205, 42, 0.08);
    border: 1px solid rgba(65, 205, 42, 0.22);
    font-size: 12px; font-weight: 500; color: var(--db-primary);
    margin-bottom: 22px;
  }
  .db-hero .badge .dot {
    width: 6px; height: 6px; border-radius: 50%; background: var(--db-primary-vivid);
    box-shadow: 0 0 0 3px rgba(65, 205, 42, 0.18);
    animation: pulse 2s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% { box-shadow: 0 0 0 3px rgba(65, 205, 42, 0.18); }
    50% { box-shadow: 0 0 0 6px rgba(65, 205, 42, 0.08); }
  }
  .db-hero h1 {
    font-size: 58px; font-weight: 800;
    line-height: 0.96; letter-spacing: -0.028em;
    margin: 0; color: var(--db-text);
  }
