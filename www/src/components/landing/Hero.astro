  .results-pagination .sep { color: #d0d0d6; }
  .results-pagination .right { margin-left: auto; display: inline-flex; align-items: center; gap: 4px; font-variant-numeric: tabular-nums; }
  .results-pagination .nav { width: 18px; height: 18px; display: inline-flex; align-items: center; justify-content: center; color: #9a9aa0; }
  .results-pagination .page { padding: 1px 6px; border-radius: 4px; color: var(--db-text); }
  .results-pagination .page.active { background: var(--db-primary); color: #fff; }

  /* Copilot */
  .cop-panel { background: #fff; display: flex; flex-direction: column; font-size: 11px; min-height: 0; }
  .cop-panel .hdr {
    background: #0a0a0b;
