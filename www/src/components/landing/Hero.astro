  .cop-panel .hdr .subtitle { font-size: 9px; color: #9a9aa0; margin-left: 2px; }
  .cop-panel .hdr .spacer { flex: 1; }
  .cop-panel .hdr .close { color: #9a9aa0; font-size: 13px; }

  .cop-panel .content {
    flex: 1;
