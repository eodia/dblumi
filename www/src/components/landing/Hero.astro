<script>
  import { startHeroAnimation } from '../landing-mock/hero-animation';
  import { strings } from '../../content/landing-strings';

  // Detect which language the page is running in by checking the URL path
  const lang = window.location.pathname.startsWith('/fr/') || window.location.pathname === '/fr' ? 'fr' : 'en';
  const m = strings[lang].hero.mockup;

  document.addEventListener('DOMContentLoaded', () => {
    startHeroAnimation({
      question: m.animUserQuestion,
      aiIntro: m.animAiIntro,
    });
  });
