  }
  .sidebar .sb-account .chev-switch { color: #b0b0b6; flex-shrink: 0; }

  /* Main column */
  .main-col { display: flex; flex-direction: column; min-width: 0; }

  .tabs-row {
    display: flex; align-items: stretch;
    background: var(--db-muted);
    border-bottom: 1px solid var(--db-border-subtle);
    height: 32px;
  }
  .tab {
    padding: 0 12px;
    font-size: 10.5px;
    color: var(--db-muted-fg);
    display: flex; align-items: center; gap: 7px;
    border-right: 1px solid var(--db-border-subtle);
    font-family: 'JetBrains Mono', monospace;
    box-sizing: border-box;
    position: relative;
  }
  .tab.active { background: #fff; color: var(--db-text); }
  .tab.active::after {
    content: ""; position: absolute; left: 0; right: 0; bottom: -1px; height: 2px;
    background: var(--db-primary-vivid);
  }
  .tab .close { opacity: 0.4; font-size: 11px; }
  .tabs-row .newtab {
    width: 28px; display: flex; align-items: center; justify-content: center;
    color: #b0b0b6;
    border-right: 1px solid var(--db-border-subtle);
  }
  .tabs-row .spacer { flex: 1; }
  .tabs-row .actions { display: flex; align-items: center; gap: 6px; padding: 0 8px; }
  .tab-btn {
    display: inline-flex;
    flex-direction: row;
    align-items: center;
    justify-content: flex-start;
    gap: 5px;
    height: 22px; padding: 0 10px;
    font-size: 10.5px; font-weight: 600;
    font-family: inherit;
    line-height: 1;
    white-space: nowrap;
    border-radius: 6px;
    cursor: pointer;
    border: 1px solid var(--db-border);
    background: #fff;
    color: var(--db-text-soft);
    box-sizing: border-box;
  }
  .tab-btn > svg {
    display: block !important;
    flex-shrink: 0;
    vertical-align: middle;
  }
  .tab-btn.primary {
    background: var(--db-primary);
    border-color: var(--db-primary);
    color: #fff;
    box-shadow: 0 1px 2px rgba(45, 163, 30, 0.25);
    position: relative;
  }
  .tab-btn.copilot {
    color: var(--db-primary);
    border-color: rgba(65, 205, 42, 0.4);
    background: rgba(65, 205, 42, 0.08);
  }
  .tab-btn.copilot::before {
    content: "✦";
    font-size: 13px;
    line-height: 1;
    color: currentColor;
    display: inline-block;
    vertical-align: middle;
    margin-right: 1px;
  }
  .tab-btn.clicked { animation: btn-click 0.25s ease-out; }
  @keyframes btn-click {
    0% { transform: scale(1); }
    35% { transform: scale(0.92); filter: brightness(1.15); }
    100% { transform: scale(1); }
  }
  .tab-btn.primary .spinner {
    display: none;
    width: 10px; height: 10px;
    border-radius: 50%;
    border: 1.5px solid rgba(255,255,255,0.4);
    border-top-color: #fff;
    animation: spin 0.7s linear infinite;
  }
  .tab-btn.primary.loading .spinner { display: inline-block; }
  .tab-btn.primary.loading .play-icon { display: none; }
  @keyframes spin { to { transform: rotate(360deg); } }

  .below-tabs {
    display: grid;
    grid-template-columns: 1fr 220px;
    flex: 1;
    min-height: 0;
  }

  .editor-area {
    display: flex; flex-direction: column;
    min-height: 0;
    border-right: 1px solid var(--db-border-subtle);
    background: #fff;
  }
  .editor {
    flex: 1 1 auto;
    min-height: 120px;
    padding: 8px 0;
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    line-height: 1.8;
    color: var(--db-text-soft);
    position: relative;
    overflow: hidden;
    background: #fff;
  }
  .editor-empty {
    position: absolute;
    inset: 16px 14px auto 62px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11.5px;
    letter-spacing: 0.01em;
    transition: opacity 0.3s;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: linear-gradient(90deg, #d0d0d6 0%, #8a8a92 40%, #d0d0d6 80%);
    background-size: 200% 100%;
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    animation: emptyShimmer 4s ease-in-out infinite;
  }
  .editor-empty::before {
    content: "";
    display: inline-block;
    width: 2px;
    height: 13px;
    background: var(--db-primary-vivid);
    animation: blink 1s step-end infinite;
    flex-shrink: 0;
    box-shadow: 0 0 4px rgba(65, 205, 42, 0.4);
    -webkit-background-clip: initial;
    background-clip: initial;
  }
  @keyframes emptyShimmer {
    0%, 100% { background-position: 200% 0; }
    50% { background-position: 0 0; }
  }
  .editor.has-content .editor-empty { opacity: 0; pointer-events: none; }
  /* Runtime-created elements need :global() since Astro scoping only tags build-time DOM */
  .editor :global(.line) {
    display: flex;
    align-items: stretch;
    padding: 0;
    white-space: nowrap;
    min-height: 24px;
    position: relative;
  }
  .editor :global(.line:hover) { background: rgba(65, 205, 42, 0.04); }
  .editor :global(.ln) {
    color: #b0b0b6;
    display: inline-flex;
    align-items: center;
    justify-content: flex-end;
    width: 44px;
    padding: 0 14px 0 0;
    flex-shrink: 0;
    user-select: none;
    font-size: 10.5px;
    font-weight: 500;
    border-right: 1px solid var(--db-border-subtle);
    background: #fafaf9;
    box-sizing: border-box;
  }
  .editor :global(.code) {
    flex: 1;
    position: relative;
    padding: 2px 16px;
    min-width: 0;
    white-space: pre;
    display: inline-flex;
    align-items: center;
  }
  .editor :global(.code) > :global(span) { white-space: pre; }
  .editor :global(.kw) { color: #c026d3; font-weight: 600; }
  .editor :global(.fn) { color: #8b5cf6; font-weight: 500; }
  .editor :global(.str) { color: #059669; }
  .editor :global(.cm) { color: #94a3b8; font-style: italic; }
  .editor :global(.cursor) {
    display: inline-block;
    width: 2px;
    height: 15px;
    background: var(--db-primary-vivid);
    vertical-align: -3px;
    margin-left: 1px;
    animation: blink 1s step-end infinite;
    box-shadow: 0 0 4px rgba(65, 205, 42, 0.4);
  }
  @keyframes blink { 0%, 50% { opacity: 1; } 50.01%, 100% { opacity: 0; } }

  /* Results */
  .results-wrap {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.55s cubic-bezier(0.4, 0, 0.2, 1);
    border-top: 1px solid var(--db-border-subtle);
