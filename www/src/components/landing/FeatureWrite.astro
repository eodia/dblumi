---
import { strings, type Lang } from '../../content/landing-strings';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = strings[lang].write;

const parts = t.headline.split('{{accent}}');
const headBefore = parts[0] ?? '';
const headAfter = parts[1] ?? '';
---

<section class="db-feat-write">
  <div class="wrap">
    <div class="row">
      <div class="text">
        <span class="label">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
          {t.label}
        </span>
        <h2>{headBefore}<span class="kalam">{headAfter}</span></h2>
        <p class="lead" set:html={t.lead}></p>
        <ul class="bullets">
          {t.bullets.map((b) => (
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              {b}
            </li>
          ))}
        </ul>
      </div>

      <div class="visual">
        <div class="mock">
          <div class="chrome">
            <div class="d d1"></div><div class="d d2"></div><div class="d d3"></div>
            <span class="path">eodia / active_users.sql</span>
          </div>
          <div class="editor">
            <div class="line-row">
              <span class="ln">1</span>
              <span class="typed l1"><span class="cm">-- Active users in the last 30 days</span></span>
            </div>
            <div class="line-row">
              <span class="ln">2</span>
              <span class="typed l2a"><span class="kw">SELECT</span> u.</span><!--
              --><span class="typed l2b">name</span><!--
              --><span class="typed l2c">, u.</span><!--
              --><span class="typed l2d">email</span>
            </div>
            <div class="line-row">
              <span class="ln">3</span>
              <span class="typed l3"><span class="kw">FROM</span> users u</span>
            </div>
            <div class="line-row">
              <span class="ln">4</span>
              <span class="typed l4a"><span class="kw">WHERE</span> u.</span><!--
              --><span class="typed l4b">last_seen</span><!--
              --><span class="typed l4c"> <span class="op">&gt;=</span> <span class="fn">NOW</span>() - <span class="kw">INTERVAL</span> <span class="str">'30 days'</span></span>
              <span class="cursor-bar"></span>
            </div>

            <div class="autocomplete">
              <div class="ac-item">
                <span class="ic key">K</span>
                <span class="name">id</span>
                <span class="type">uuid</span>
              </div>
              <div class="ac-item">
                <span class="ic">c</span>
                <span class="name">name</span>
                <span class="type">text</span>
              </div>
              <div class="ac-item">
                <span class="ic">c</span>
                <span class="name">email</span>
                <span class="type">text</span>
              </div>
              <div class="ac-item">
                <span class="ic">c</span>
                <span class="name">last_seen</span>
                <span class="type">timestamp</span>
              </div>
              <div class="ac-item">
                <span class="ic">c</span>
                <span class="name">org_id</span>
                <span class="type">uuid</span>
              </div>
              <div class="ac-item">
                <span class="ic">c</span>
                <span class="name">created_at</span>
                <span class="type">timestamp</span>
              </div>
              <div class="ac-footer">
                <span><span class="kbd">↑↓</span> navigate</span>
                <span><span class="kbd">↹</span> accept</span>
                <span style="margin-left:auto">6 columns · AI ranked</span>
              </div>
            </div>

            <div class="speed-pill" aria-hidden="true">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor"><path d="M13 2L3 14h7l-1 8 10-12h-7l1-8z"/></svg>
              <span>typing at the speed of thought</span>
            </div>
          </div>
          <div class="statusbar">
            <span class="dot"></span>
            eodia · postgresql · Ln 4, Col 48 · SQL
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>

  .db-feat-write {
    padding: 96px 56px;
    background: #fff;
    margin: 0;
  }
  .db-feat-write .wrap {
    max-width: 1080px;
    margin: 0 auto;
  }
  .db-feat-write .row {
    display: grid;
    grid-template-columns: 0.9fr 1.2fr;
    gap: 72px;
    align-items: center;
  }

  .label {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 10.5px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--db-primary, #2DA31E);
    padding: 5px 10px;
    border: 1px solid rgba(65, 205, 42, 0.3);
    border-radius: 100px;
    background: rgba(65, 205, 42, 0.07);
    margin-bottom: 22px;
  }
  h2 {
    font-size: 46px;
    font-weight: 800;
    line-height: 1.0;
    letter-spacing: -0.025em;
    margin: 0 0 20px;
    color: var(--db-text, #0A0A0B);
    max-width: 14ch;
  }
  h2 .kalam {
    font-family: 'Kalam', cursive;
    font-weight: 700;
    color: var(--db-primary-vivid, #41cd2a);
  }
  p.lead {
    font-size: 16px;
    color: var(--db-muted-fg, #6B6B76);
    line-height: 1.6;
    max-width: 44ch;
    margin: 0 0 24px;
  }
  p.lead :global(strong) {
    color: var(--db-text, #0A0A0B);
    font-weight: 600;
    background: linear-gradient(180deg, transparent 58%, rgba(65, 205, 42, 0.28) 58%);
    padding: 0 2px;
    border-radius: 2px;
    box-decoration-break: clone;
    -webkit-box-decoration-break: clone;
  }
  ul.bullets {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  ul.bullets li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 14px;
    color: var(--db-text-soft, #3A3A42);
    line-height: 1.45;
  }
  ul.bullets li svg {
    flex-shrink: 0;
    color: var(--db-primary, #2DA31E);
    margin-top: 2px;
  }

  /* Generic mockup chrome */
  .mock {
    border: 1px solid var(--db-border, #E2E2E6);
    border-radius: 12px;
    background: var(--db-card, #FFFFFF);
    overflow: hidden;
    box-shadow:
      0 40px 80px -24px rgba(10, 10, 15, 0.20),
      0 16px 32px -16px rgba(10, 10, 15, 0.12);
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
  }
  .chrome {
    height: 28px;
    background: #f7f7f6;
    border-bottom: 1px solid var(--db-border-subtle, #EDEDF0);
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 0 10px;
  }
  .chrome .d {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }
  .chrome .d1 { background: #ff5f57; }
  .chrome .d2 { background: #febc2e; }
  .chrome .d3 { background: #28c840; }
  .chrome .path {
    margin-left: 12px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    color: #9a9aa0;
  }
  /* Token colors */
  .kw { color: #1e40af; font-weight: 500; }
  .fn { color: #8b5cf6; }
  .str { color: var(--db-primary, #2DA31E); }
  .cm { color: #a0a0a0; font-style: italic; }
  .num { color: #d97706; }
  .op { color: #c026d3; font-weight: 500; }

  /* Solo writer mockup — focused on typing speed + autocomplete */
  .editor {
    padding: 22px 14px 28px;
    min-height: 340px;
    background: #fff;
    line-height: 1.95;
    font-size: 13px;
    color: var(--db-text-soft, #3A3A42);
    position: relative;
  }
  .line-row {
    display: flex;
    align-items: baseline;
    white-space: nowrap;
  }
  .editor .ln {
    color: #c5c5ca;
    display: inline-block;
    width: 18px;
    text-align: right;
    margin-right: 14px;
    user-select: none;
    font-size: 11px;
    flex-shrink: 0;
  }
  /* Each line segment is revealed char-by-char via max-width + steps() */
  .typed {
    display: inline-block;
    overflow: hidden;
    white-space: nowrap;
    max-width: 0;
    vertical-align: bottom;
  }
  /* 8s loop — line 1, line 2 split into 4 segments, line 3, line 4 split into 3 */
  .l1  { animation: typeL1  8s steps(36, end) infinite; }
  .l2a { animation: typeL2a 8s steps(9, end)  infinite; }
  .l2b { animation: typeL2b 8s steps(1, end)  infinite; }
  .l2c { animation: typeL2c 8s steps(4, end)  infinite; }
  .l2d { animation: typeL2d 8s steps(1, end)  infinite; }
  .l3  { animation: typeL3  8s steps(12, end) infinite; }
  .l4a { animation: typeL4a 8s steps(8, end)  infinite; }
  .l4b { animation: typeL4b 8s steps(1, end)  infinite; }
  .l4c { animation: typeL4c 8s steps(30, end) infinite; }

  @keyframes typeL1 {
    0%, 2% { max-width: 0; }
    10% { max-width: 36ch; }
    96% { max-width: 36ch; }
    98%, 100% { max-width: 0; }
  }
  /* Line 2: "SELECT u." typed, then "name" accepted, then ", u.", then "email" accepted */
  @keyframes typeL2a {
    0%, 14% { max-width: 0; }
    19% { max-width: 9ch; }
    96% { max-width: 9ch; }
    98%, 100% { max-width: 0; }
  }
  @keyframes typeL2b {
    0%, 21% { max-width: 0; }
    22% { max-width: 4ch; }
    96% { max-width: 4ch; }
    98%, 100% { max-width: 0; }
  }
  @keyframes typeL2c {
    0%, 22% { max-width: 0; }
    24% { max-width: 4ch; }
    96% { max-width: 4ch; }
    98%, 100% { max-width: 0; }
  }
  @keyframes typeL2d {
    0%, 26% { max-width: 0; }
    27% { max-width: 5ch; }
    96% { max-width: 5ch; }
    98%, 100% { max-width: 0; }
  }
  @keyframes typeL3 {
    0%, 29% { max-width: 0; }
    33% { max-width: 12ch; }
    96% { max-width: 12ch; }
    98%, 100% { max-width: 0; }
  }
  /* Line 4: "WHERE u." typed, then "last_seen" accepted, then " >= NOW() - INTERVAL '30 days'" typed slowly */
  @keyframes typeL4a {
    0%, 35% { max-width: 0; }
    40% { max-width: 8ch; }
    96% { max-width: 8ch; }
    98%, 100% { max-width: 0; }
  }
  @keyframes typeL4b {
    0%, 43% { max-width: 0; }
    44% { max-width: 9ch; }
    96% { max-width: 9ch; }
    98%, 100% { max-width: 0; }
  }
  @keyframes typeL4c {
    0%, 46% { max-width: 0; }
    82% { max-width: 30ch; }    /* 36% of 8s = 2.88s for 30 chars — "human slow" */
    96% { max-width: 30ch; }
    98%, 100% { max-width: 0; }
  }

  /* Local caret blinks at the end of the current input */
  .cursor-bar {
    display: inline-block;
    width: 2px;
    height: 15px;
    background: var(--db-primary-vivid, #41cd2a);
    vertical-align: -2px;
    margin-left: 1px;
    animation: blink 1s step-end infinite;
    box-shadow: 0 0 4px rgba(65, 205, 42, 0.4);
  }
  @keyframes blink {
    0%, 50% { opacity: 1; }
    50.01%, 100% { opacity: 0; }
  }

  .autocomplete {
    position: absolute;
    left: 122px;
    background: #fff;
    border: 1px solid var(--db-border, #E2E2E6);
    border-radius: 8px;
    box-shadow:
      0 20px 40px -12px rgba(10, 10, 15, 0.25),
      0 8px 16px -8px rgba(10, 10, 15, 0.1);
    width: 220px;
    overflow: hidden;
    font-family: 'Inter', sans-serif;
    font-size: 11.5px;
    z-index: 10;
    opacity: 0;
    top: 72px;
    animation: acPosition 8s ease infinite;
  }
  /* Popup hops between line 2 (top 72) and line 4 (top 122),
     and disappears right after "last_seen" is accepted */
  @keyframes acPosition {
    0%, 13% { opacity: 0; top: 72px; }
    15% { opacity: 1; top: 72px; }        /* appears near line 2 as "SELECT u." is typed */
    28% { opacity: 1; top: 72px; }        /* hold through name + , u. + email accepts */
    29% { opacity: 0; top: 72px; }
    /* Jump to line 4 position */
    34% { opacity: 0; top: 122px; }
    36% { opacity: 1; top: 122px; }       /* appears near line 4 as "WHERE u." is typed */
    43% { opacity: 1; top: 122px; }       /* hold on last_seen highlight */
    44% { opacity: 1; top: 122px; filter: drop-shadow(0 0 12px rgba(65, 205, 42, 0.6)); }
    46% { opacity: 0; top: 122px; filter: none; } /* disappears right after accept */
    100% { opacity: 0; top: 122px; }
  }
  /* Moving selection highlight — jumps to name → email → last_seen at the right moments.
     Positioned inside the .autocomplete which starts below the 1px top border,
     so we add 1px offset and use exact .ac-item heights (padding 6+15+6+border = 28px). */
  .autocomplete::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    height: 28px;
    top: 29px;
    background: rgba(65, 205, 42, 0.14);
    border-left: 2px solid var(--db-primary, #2DA31E);
    box-sizing: border-box;
    pointer-events: none;
    opacity: 0;
    z-index: 1;
    animation: acHighlight 8s ease infinite;
  }
  @keyframes acHighlight {
    /* Start hidden, parked on name row */
    0%, 14% { top: 29px; opacity: 0; }
    /* "SELECT u." done → highlight "name" (row 2) */
    16% { top: 29px; opacity: 1; }
    21% { top: 29px; opacity: 1; }
    22% { top: 29px; opacity: 0.35; }                 /* accept flash */
    /* Move to "email" (row 3) */
    23% { top: 57px; opacity: 0; }
    25% { top: 57px; opacity: 1; }
    26% { top: 57px; opacity: 1; }
    27% { top: 57px; opacity: 0.35; }                 /* accept flash */
    /* Hide during line 3 */
    28%, 35% { top: 57px; opacity: 0; }
    /* Highlight "last_seen" (row 4) */
    37% { top: 85px; opacity: 0; }
    41% { top: 85px; opacity: 1; }
    43% { top: 85px; opacity: 1; }
    44% { top: 85px; opacity: 0.35; }                 /* accept flash */
    /* Popup disappears just after — keep highlight hidden for the rest */
    45%, 100% { top: 85px; opacity: 0; }
  }
  .autocomplete .ac-item {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 6px 10px;
    color: var(--db-text-soft, #3A3A42);
    border-bottom: 1px solid var(--db-border-subtle, #EDEDF0);
  }
  .autocomplete .ac-item:last-child { border-bottom: 0; }
  .autocomplete .ac-item.selected {
    background: rgba(65, 205, 42, 0.10);
    color: var(--db-primary, #2DA31E);
  }
  .autocomplete .ac-item .ic {
    width: 14px;
    height: 14px;
    border-radius: 3px;
    background: var(--db-muted, #F0F0F2);
    color: var(--db-muted-fg, #6B6B76);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    font-weight: 700;
    flex-shrink: 0;
  }
  .autocomplete .ac-item.selected .ic {
    background: rgba(65, 205, 42, 0.15);
    color: var(--db-primary, #2DA31E);
  }
  .autocomplete .ac-item .ic.key {
    color: var(--db-warning, #F59E0B);
    background: rgba(245, 158, 11, 0.12);
  }
  .autocomplete .ac-item .name {
    font-family: 'JetBrains Mono', monospace;
    font-weight: 500;
    flex: 1;
  }
  .autocomplete .ac-item .type {
    font-size: 9px;
    color: #b0b0b6;
    font-family: 'JetBrains Mono', monospace;
  }
  .autocomplete .ac-footer {
    padding: 5px 10px;
    font-size: 9px;
    color: #9a9aa0;
    background: #fdfdfc;
    border-top: 1px solid var(--db-border-subtle, #EDEDF0);
    display: flex;
    gap: 10px;
  }
  .autocomplete .ac-footer .kbd {
    padding: 0 5px;
    border: 1px solid var(--db-border, #E2E2E6);
    border-radius: 3px;
    background: #fff;
    font-family: 'JetBrains Mono', monospace;
  }

  /* Speed pill — floats in the editor's bottom-left corner */
  .speed-pill {
    position: absolute;
    bottom: 14px;
    left: 14px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 5px 10px 5px 8px;
    background: #ffffff;
    border: 1px solid rgba(65, 205, 42, 0.3);
    border-radius: 100px;
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 10px;
    font-weight: 600;
    color: var(--db-primary, #2DA31E);
    box-shadow: 0 4px 14px -4px rgba(65, 205, 42, 0.3);
    animation: speedPulse 2.4s ease-in-out infinite;
  }
  .speed-pill svg {
    color: var(--db-primary-vivid, #41cd2a);
    flex-shrink: 0;
  }
  @keyframes speedPulse {
    0%, 100% { box-shadow: 0 4px 14px -4px rgba(65, 205, 42, 0.3); }
    50% { box-shadow: 0 6px 22px -4px rgba(65, 205, 42, 0.5); }
  }

  @media (prefers-reduced-motion: reduce) {
    .typed,
    .autocomplete,
    .autocomplete .accept-hint,
    .speed-pill,
    .cursor-bar { animation: none; }
    .typed { max-width: 100ch; }
    .autocomplete { opacity: 1; transform: none; }
  }

  .mock .statusbar {
    display: flex;
    align-items: center;
    padding: 7px 14px;
    border-top: 1px solid var(--db-border-subtle, #EDEDF0);
    background: #fdfdfc;
    font-size: 10px;
    color: var(--db-muted-fg, #6B6B76);
    font-family: 'Inter', sans-serif;
  }
  .mock .statusbar .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--db-primary-vivid, #41cd2a);
    margin-right: 6px;
  }

  @media (max-width: 980px) {
    .db-feat-write {
      padding: 56px 24px;
    }
    .db-feat-write .row {
      grid-template-columns: 1fr;
      gap: 36px;
    }
    .autocomplete {
      position: static;
      width: 100%;
      margin-top: 10px;
    }
  }
</style>
