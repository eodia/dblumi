---
import { strings, type Lang } from '../../content/landing-strings';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = strings[lang].write;

const parts = t.headline.split('{{accent}}');
const headBefore = parts[0] ?? '';
const headAfter = parts[1] ?? '';
---

<section class="db-feat-write">
  <div class="wrap">
    <div class="row">
      <div class="text">
        <span class="label">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
          {t.label}
        </span>
        <h2>{headBefore}<span class="kalam">{headAfter}</span></h2>
        <p class="lead" set:html={t.lead}></p>
        <ul class="bullets">
          {t.bullets.map((b) => (
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              {b}
            </li>
          ))}
        </ul>
      </div>

      <div class="visual">
        <div class="mock">
          <div class="chrome">
            <div class="d d1"></div><div class="d d2"></div><div class="d d3"></div>
            <span class="path">eodia / active_users.sql</span>
          </div>
          <div class="editor">
            <div class="line-row">
              <span class="ln">1</span>
              <span class="typed l1"><span class="cm">-- Active users in the last 30 days</span></span>
            </div>
            <div class="line-row">
              <span class="ln">2</span>
              <span class="typed l2"><span class="kw">SELECT</span> u.name, u.email</span>
            </div>
            <div class="line-row">
              <span class="ln">3</span>
              <span class="typed l3"><span class="kw">FROM</span> users u</span>
            </div>
            <div class="line-row">
              <span class="ln">4</span>
              <span class="typed l4"><span class="kw">WHERE</span> u.last_seen <span class="op">&gt;=</span> <span class="fn">NOW</span>() - <span class="kw">INTERVAL</span> <span class="str">'30 days'</span></span>
              <span class="cursor-bar"></span>
            </div>

            <div class="autocomplete">
              <div class="ac-item">
                <span class="ic key">K</span>
                <span class="name">id</span>
                <span class="type">uuid</span>
              </div>
              <div class="ac-item">
                <span class="ic">c</span>
                <span class="name">name</span>
                <span class="type">text</span>
              </div>
              <div class="ac-item">
                <span class="ic">c</span>
                <span class="name">email</span>
                <span class="type">text</span>
              </div>
              <div class="ac-item selected">
                <span class="ic">c</span>
                <span class="name">last_seen</span>
                <span class="type">timestamp</span>
                <span class="accept-hint"><kbd>↹</kbd> accept</span>
              </div>
              <div class="ac-item">
                <span class="ic">c</span>
                <span class="name">org_id</span>
                <span class="type">uuid</span>
              </div>
              <div class="ac-item">
                <span class="ic">c</span>
                <span class="name">created_at</span>
                <span class="type">timestamp</span>
              </div>
              <div class="ac-footer">
                <span><span class="kbd">↑↓</span> navigate</span>
                <span><span class="kbd">⏎</span> insert</span>
                <span style="margin-left:auto">6 columns · AI ranked</span>
              </div>
            </div>

            <div class="speed-pill" aria-hidden="true">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor"><path d="M13 2L3 14h7l-1 8 10-12h-7l1-8z"/></svg>
              <span>typing at the speed of thought</span>
            </div>
          </div>
          <div class="statusbar">
            <span class="dot"></span>
            eodia · postgresql · Ln 4, Col 48 · SQL
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>

  .db-feat-write {
    padding: 96px 56px;
    background: #fff;
    margin: 0;
  }
  .db-feat-write .wrap {
    max-width: 1080px;
    margin: 0 auto;
  }
  .db-feat-write .row {
    display: grid;
    grid-template-columns: 0.9fr 1.2fr;
    gap: 72px;
    align-items: center;
  }

  .label {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 10.5px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--db-primary, #2DA31E);
    padding: 5px 10px;
    border: 1px solid rgba(65, 205, 42, 0.3);
    border-radius: 100px;
    background: rgba(65, 205, 42, 0.07);
    margin-bottom: 22px;
  }
  h2 {
    font-size: 46px;
    font-weight: 800;
    line-height: 1.0;
    letter-spacing: -0.025em;
    margin: 0 0 20px;
    color: var(--db-text, #0A0A0B);
    max-width: 14ch;
  }
  h2 .kalam {
    font-family: 'Kalam', cursive;
    font-weight: 700;
    color: var(--db-primary-vivid, #41cd2a);
  }
  p.lead {
    font-size: 16px;
    color: var(--db-muted-fg, #6B6B76);
    line-height: 1.6;
    max-width: 44ch;
    margin: 0 0 24px;
  }
  p.lead :global(strong) {
    color: var(--db-text, #0A0A0B);
    font-weight: 600;
    background: linear-gradient(180deg, transparent 58%, rgba(65, 205, 42, 0.28) 58%);
    padding: 0 2px;
    border-radius: 2px;
    box-decoration-break: clone;
    -webkit-box-decoration-break: clone;
  }
  ul.bullets {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  ul.bullets li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 14px;
    color: var(--db-text-soft, #3A3A42);
    line-height: 1.45;
  }
  ul.bullets li svg {
    flex-shrink: 0;
    color: var(--db-primary, #2DA31E);
    margin-top: 2px;
  }

  /* Generic mockup chrome */
  .mock {
    border: 1px solid var(--db-border, #E2E2E6);
    border-radius: 12px;
    background: var(--db-card, #FFFFFF);
    overflow: hidden;
    box-shadow:
      0 40px 80px -24px rgba(10, 10, 15, 0.20),
      0 16px 32px -16px rgba(10, 10, 15, 0.12);
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
  }
  .chrome {
    height: 28px;
    background: #f7f7f6;
    border-bottom: 1px solid var(--db-border-subtle, #EDEDF0);
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 0 10px;
  }
  .chrome .d {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }
  .chrome .d1 { background: #ff5f57; }
  .chrome .d2 { background: #febc2e; }
  .chrome .d3 { background: #28c840; }
  .chrome .path {
    margin-left: 12px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    color: #9a9aa0;
  }
  /* Token colors */
  .kw { color: #1e40af; font-weight: 500; }
  .fn { color: #8b5cf6; }
  .str { color: var(--db-primary, #2DA31E); }
  .cm { color: #a0a0a0; font-style: italic; }
  .num { color: #d97706; }
  .op { color: #c026d3; font-weight: 500; }

  /* Solo writer mockup — focused on typing speed + autocomplete */
  .editor {
    padding: 22px 14px 28px;
    min-height: 340px;
    background: #fff;
    line-height: 1.95;
    font-size: 13px;
    color: var(--db-text-soft, #3A3A42);
    position: relative;
  }
  .line-row {
    display: flex;
    align-items: baseline;
    white-space: nowrap;
  }
  .editor .ln {
    color: #c5c5ca;
    display: inline-block;
    width: 18px;
    text-align: right;
    margin-right: 14px;
    user-select: none;
    font-size: 11px;
    flex-shrink: 0;
  }
  /* Each line is revealed char-by-char via max-width + steps() */
  .typed {
    display: inline-block;
    overflow: hidden;
    white-space: nowrap;
    max-width: 0;
    vertical-align: bottom;
  }
  /* 8s loop split into reveal segments + hold + fade-out */
  .l1 { animation: typeL1 8s steps(36, end) infinite; }
  .l2 { animation: typeL2 8s steps(22, end) infinite; }
  .l3 { animation: typeL3 8s steps(12, end) infinite; }
  .l4 { animation: typeL4 8s steps(47, end) infinite; }

  @keyframes typeL1 {
    0%, 2% { max-width: 0; }
    15% { max-width: 36ch; }
    94% { max-width: 36ch; }
    96%, 100% { max-width: 0; }
  }
  @keyframes typeL2 {
    0%, 17% { max-width: 0; }
    28% { max-width: 22ch; }
    94% { max-width: 22ch; }
    96%, 100% { max-width: 0; }
  }
  @keyframes typeL3 {
    0%, 30% { max-width: 0; }
    36% { max-width: 12ch; }
    94% { max-width: 12ch; }
    96%, 100% { max-width: 0; }
  }
  @keyframes typeL4 {
    /* Types "WHERE u." slowly, then jumps to full line after "Tab" accept */
    0%, 38% { max-width: 0; }
    43% { max-width: 8ch; }    /* WHERE u. */
    48% { max-width: 8ch; }    /* pause — waiting on autocomplete */
    52% { max-width: 47ch; }   /* accept → insert "last_seen >= NOW() - INTERVAL '30 days'" */
    94% { max-width: 47ch; }
    96%, 100% { max-width: 0; }
  }

  /* Local caret blinks at the end of the current input */
  .cursor-bar {
    display: inline-block;
    width: 2px;
    height: 15px;
    background: var(--db-primary-vivid, #41cd2a);
    vertical-align: -2px;
    margin-left: 1px;
    animation: blink 1s step-end infinite;
    box-shadow: 0 0 4px rgba(65, 205, 42, 0.4);
  }
  @keyframes blink {
    0%, 50% { opacity: 1; }
    50.01%, 100% { opacity: 0; }
  }

  .autocomplete {
    position: absolute;
    top: 122px;
    left: 122px;
    background: #fff;
    border: 1px solid var(--db-border, #E2E2E6);
    border-radius: 8px;
    box-shadow:
      0 20px 40px -12px rgba(10, 10, 15, 0.25),
      0 8px 16px -8px rgba(10, 10, 15, 0.1);
    width: 230px;
    overflow: hidden;
    font-family: 'Inter', sans-serif;
    font-size: 11.5px;
    z-index: 10;
    opacity: 0;
    transform: translateY(-4px);
    animation: acReveal 8s cubic-bezier(0.22, 1, 0.36, 1) infinite;
  }
  /* Popup fades in as "u." is typed, highlights during "Tab accept", then fades out */
  @keyframes acReveal {
    0%, 38% { opacity: 0; transform: translateY(-4px); }
    43%, 48% { opacity: 1; transform: translateY(0); }
    52% { opacity: 1; transform: translateY(0); filter: drop-shadow(0 0 12px rgba(65, 205, 42, 0.55)); }
    56%, 94% { opacity: 1; transform: translateY(0); filter: none; }
    96%, 100% { opacity: 0; transform: translateY(-4px); }
  }
  .autocomplete .accept-hint {
    margin-left: auto;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 9px;
    font-weight: 600;
    color: var(--db-primary, #2DA31E);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    animation: acceptHintPulse 8s ease-in-out infinite;
  }
  .autocomplete .accept-hint kbd {
    padding: 1px 6px;
    border: 1px solid rgba(65, 205, 42, 0.3);
    border-bottom-width: 2px;
    border-radius: 4px;
    background: rgba(65, 205, 42, 0.08);
    font-family: 'JetBrains Mono', monospace;
    color: var(--db-primary, #2DA31E);
  }
  @keyframes acceptHintPulse {
    0%, 43% { opacity: 0; transform: scale(0.9); }
    46% { opacity: 1; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.1); }
    54% { opacity: 0; transform: scale(1); }
    100% { opacity: 0; }
  }
  .autocomplete .ac-item {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 6px 10px;
    color: var(--db-text-soft, #3A3A42);
    border-bottom: 1px solid var(--db-border-subtle, #EDEDF0);
  }
  .autocomplete .ac-item:last-child { border-bottom: 0; }
  .autocomplete .ac-item.selected {
    background: rgba(65, 205, 42, 0.10);
    color: var(--db-primary, #2DA31E);
  }
  .autocomplete .ac-item .ic {
    width: 14px;
    height: 14px;
    border-radius: 3px;
    background: var(--db-muted, #F0F0F2);
    color: var(--db-muted-fg, #6B6B76);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    font-weight: 700;
    flex-shrink: 0;
  }
  .autocomplete .ac-item.selected .ic {
    background: rgba(65, 205, 42, 0.15);
    color: var(--db-primary, #2DA31E);
  }
  .autocomplete .ac-item .ic.key {
    color: var(--db-warning, #F59E0B);
    background: rgba(245, 158, 11, 0.12);
  }
  .autocomplete .ac-item .name {
    font-family: 'JetBrains Mono', monospace;
    font-weight: 500;
    flex: 1;
  }
  .autocomplete .ac-item .type {
    font-size: 9px;
    color: #b0b0b6;
    font-family: 'JetBrains Mono', monospace;
  }
  .autocomplete .ac-footer {
    padding: 5px 10px;
    font-size: 9px;
    color: #9a9aa0;
    background: #fdfdfc;
    border-top: 1px solid var(--db-border-subtle, #EDEDF0);
    display: flex;
    gap: 10px;
  }
  .autocomplete .ac-footer .kbd {
    padding: 0 5px;
    border: 1px solid var(--db-border, #E2E2E6);
    border-radius: 3px;
    background: #fff;
    font-family: 'JetBrains Mono', monospace;
  }

  /* Speed pill — floats in the editor's bottom-left corner */
  .speed-pill {
    position: absolute;
    bottom: 14px;
    left: 14px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 5px 10px 5px 8px;
    background: #ffffff;
    border: 1px solid rgba(65, 205, 42, 0.3);
    border-radius: 100px;
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 10px;
    font-weight: 600;
    color: var(--db-primary, #2DA31E);
    box-shadow: 0 4px 14px -4px rgba(65, 205, 42, 0.3);
    animation: speedPulse 2.4s ease-in-out infinite;
  }
  .speed-pill svg {
    color: var(--db-primary-vivid, #41cd2a);
    flex-shrink: 0;
  }
  @keyframes speedPulse {
    0%, 100% { box-shadow: 0 4px 14px -4px rgba(65, 205, 42, 0.3); }
    50% { box-shadow: 0 6px 22px -4px rgba(65, 205, 42, 0.5); }
  }

  @media (prefers-reduced-motion: reduce) {
    .typed,
    .autocomplete,
    .autocomplete .accept-hint,
    .speed-pill,
    .cursor-bar { animation: none; }
    .typed { max-width: 100ch; }
    .autocomplete { opacity: 1; transform: none; }
  }

  .mock .statusbar {
    display: flex;
    align-items: center;
    padding: 7px 14px;
    border-top: 1px solid var(--db-border-subtle, #EDEDF0);
    background: #fdfdfc;
    font-size: 10px;
    color: var(--db-muted-fg, #6B6B76);
    font-family: 'Inter', sans-serif;
  }
  .mock .statusbar .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--db-primary-vivid, #41cd2a);
    margin-right: 6px;
  }

  @media (max-width: 980px) {
    .db-feat-write {
      padding: 56px 24px;
    }
    .db-feat-write .row {
      grid-template-columns: 1fr;
      gap: 36px;
    }
    .autocomplete {
      position: static;
      width: 100%;
      margin-top: 10px;
    }
  }
</style>
