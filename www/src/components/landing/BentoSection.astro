---
// www/src/components/landing/BentoSection.astro
import { strings, type Lang } from '../../content/landing-strings';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = strings[lang].bento;

function accent(s: string): [string, string] {
  const parts = s.split('{{accent}}');
  return [parts[0] ?? '', parts[1] ?? ''];
}

const [headBefore, headAfter] = accent(t.headline);
const [restBefore, restAfter] = accent(t.cards.rest.title);
const [mcpBefore, mcpAfter] = accent(t.cards.mcp.title);
const [shBefore, shAfter] = accent(t.cards.selfHosted.title);
const [drvBefore, drvAfter] = accent(t.cards.drivers.title);
const [erdBefore, erdAfter] = accent(t.cards.erd.title);
const [safetyBefore, safetyAfter] = accent(t.cards.safety.title);
const [i18nBefore, i18nAfter] = accent(t.cards.i18n.title);
const [hassleBefore, hassleAfter] = accent(t.cards.hassle.title);
const [drawerBefore, drawerAfter] = accent(t.cards.drawer.title);
const [verBefore, verAfter] = accent(t.cards.versioning.title);
const [gameBefore, gameAfter] = accent(t.cards.game.title);
---

<section class="bento-section">
  <div class="header">
    <span class="eyebrow">{t.eyebrow}</span>
    <h2>{headBefore}<span class="kalam">{headAfter}</span></h2>
    <p class="lead">{t.lead}</p>
  </div>

  <div class="bento">

    <!-- Row 1: REST API (span 4, light) + MCP (span 2, dark) -->
    <div class="bcard span-4">
      <span class="c-label">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
        {t.cards.rest.label}
      </span>
      <h3>{restBefore}<span class="accent">{restAfter}</span></h3>
      <p>{t.cards.rest.desc}</p>
      <div class="visual">
        <div class="mini-term">
<span class="prompt">$</span> <span class="kw">curl</span> <span class="url">https://api.eodia.net/q/regions_by_revenue</span> <span class="dim">\</span><br>
&nbsp;&nbsp;&nbsp;&nbsp;<span class="kw">-H</span> <span class="str">"X-API-Key: sk_live_a7f…"</span>
<br><br>{"{"} <span class="key">"rows"</span>: [<br>&nbsp;&nbsp;&nbsp;{"{"}<span class="key">"region"</span>: <span class="str">"North America"</span>, <span class="key">"revenue"</span>: <span class="num">1245320</span>{"}"}<span class="dim">,</span><br>&nbsp;&nbsp;&nbsp;{"{"}<span class="key">"region"</span>: <span class="str">"Europe"</span>, <span class="key">"revenue"</span>: <span class="num">987410</span>{"}"}<br>] {"}"}
        </div>
      </div>
    </div>

    <div class="bcard dark span-2">
      <span class="c-label">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 3 L13.6 10.4 L21 12 L13.6 13.6 L12 21 L10.4 13.6 L3 12 L10.4 10.4 Z"/></svg>
        {t.cards.mcp.label}
      </span>
      <h3>{mcpBefore}<span class="accent">{mcpAfter}</span></h3>
      <p>{t.cards.mcp.desc}</p>
      <div class="visual">
        <div class="mini-term">
<span class="dim">// claude_desktop_config.json</span><br>
{"{"}<br>
&nbsp;&nbsp;<span class="key">"mcpServers"</span>: {"{"}<br>
&nbsp;&nbsp;&nbsp;&nbsp;<span class="key">"dblumi"</span>: {"{"}<br>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class="key">"command"</span>: <span class="str">"npx"</span>,<br>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class="key">"args"</span>: [<span class="str">"@dblumi/mcp"</span>]<br>
&nbsp;&nbsp;&nbsp;&nbsp;{"}"}<br>
&nbsp;&nbsp;{"}"}<br>
{"}"}
        </div>
      </div>
    </div>

    <!-- Row 2: Self-hosted (span 3, dark) + Multi-driver (span 3, light) -->
    <div class="bcard dark span-3">
      <span class="c-label">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
        {t.cards.selfHosted.label}
      </span>
      <h3>{shBefore}<span class="accent">{shAfter}</span></h3>
      <p>{t.cards.selfHosted.desc}</p>
      <div class="visual">
        <div class="mini-term">
<span class="prompt">$</span> <span class="kw">docker</span> compose up -d<br>
<span class="tick">✓</span> <span class="dim">Pulled</span> eodia/dblumi:latest<br>
<span class="tick">✓</span> <span class="dim">Created</span> dblumi-api<br>
<span class="tick">✓</span> <span class="dim">Started</span> dblumi <span class="dim">(3s)</span><br>
<span class="dim">→</span> <span class="url">http://localhost:5173</span>
        </div>
      </div>
    </div>

    <div class="bcard span-3">
      <span class="c-label">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5v14c0 1.7 4 3 9 3s9-1.3 9-3V5"/><path d="M3 12c0 1.7 4 3 9 3s9-1.3 9-3"/></svg>
        {t.cards.drivers.label}
      </span>
      <h3>{drvBefore}<span class="accent">{drvAfter}</span></h3>
      <p>{t.cards.drivers.desc}</p>
      <div class="visual">
        <div class="magnetic">
          <div class="core">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5v14c0 1.7 4 3 9 3s9-1.3 9-3V5"/><path d="M3 12c0 1.7 4 3 9 3s9-1.3 9-3"/></svg>
          </div>
          <div class="chip-orbit" style="--angle: 45deg; --delay: 0s;">
            <div class="chip"><span class="logo l-pg">PG</span><span class="name">Postgres</span></div>
          </div>
          <div class="chip-orbit" style="--angle: 135deg; --delay: 0.3s;">
            <div class="chip"><span class="logo l-my">My</span><span class="name">MySQL</span></div>
          </div>
          <div class="chip-orbit" style="--angle: 225deg; --delay: 0.6s;">
            <div class="chip"><span class="logo l-or">O</span><span class="name">Oracle</span></div>
          </div>
          <div class="chip-orbit" style="--angle: 315deg; --delay: 0.9s;">
            <div class="chip"><span class="logo l-sq">SL</span><span class="name">SQLite</span></div>
          </div>
        </div>
      </div>
    </div>

    <!-- Row 3: Schema ERD (span 2) + Guardrails (span 2) + i18n (span 2) -->
    <div class="bcard span-2">
      <span class="c-label">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="7" height="5" rx="1"/><rect x="14" y="3" width="7" height="5" rx="1"/><rect x="3" y="16" width="7" height="5" rx="1"/><rect x="14" y="16" width="7" height="5" rx="1"/></svg>
        {t.cards.erd.label}
      </span>
      <h3>{erdBefore}<span class="accent">{erdAfter}</span></h3>
      <p>{t.cards.erd.desc}</p>
      <div class="visual">
        <div class="erd">
          <svg class="erd-lines" viewBox="0 0 280 100" preserveAspectRatio="none">
            <path d="M 70 24 Q 140 20 210 24" fill="none" stroke="rgba(65,205,42,0.5)" stroke-width="1.3" stroke-dasharray="3 3"/>
            <path d="M 70 34 Q 90 70 140 82" fill="none" stroke="rgba(65,205,42,0.4)" stroke-width="1.3" stroke-dasharray="3 3"/>
            <path d="M 210 34 Q 200 70 140 82" fill="none" stroke="rgba(65,205,42,0.4)" stroke-width="1.3" stroke-dasharray="3 3"/>
          </svg>
          <div class="erd-box users"><span class="tbl">users</span><span class="col">id</span></div>
          <div class="erd-box orgs"><span class="tbl">orgs</span><span class="col">id</span></div>
          <div class="erd-box orders"><span class="tbl">orders</span><span class="col">id</span></div>
        </div>
      </div>
    </div>

    <div class="bcard span-2">
      <span class="c-label">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        {t.cards.safety.label}
      </span>
      <h3>{safetyBefore}<span class="accent">{safetyAfter}</span></h3>
      <p>{t.cards.safety.desc}</p>
      <div class="visual">
        <div class="levels">
          {t.cards.safety.levels.map((lvl, i) => {
            const isActive = lvl === t.cards.safety.levelActive;
            const fillClass = `fill-${i + 1}`;
            return (
              <div class={`lvl${isActive ? ' active' : ''}`}>
                <div class="bar">
                  <span class={`seg${i >= 0 ? ` ${fillClass}` : ''}`}></span>
                  <span class={`seg${i >= 1 ? ` ${fillClass}` : ''}`}></span>
                  <span class={`seg${i >= 2 ? ` ${fillClass}` : ''}`}></span>
                  <span class={`seg${i >= 3 ? ` ${fillClass}` : ''}`}></span>
                </div>
                <span class="name">{lvl}</span>
              </div>
            );
          })}
        </div>
      </div>
    </div>

    <div class="bcard span-2">
      <span class="c-label">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
        {t.cards.i18n.label}
      </span>
      <h3>{i18nBefore}<span class="accent">{i18nAfter}</span></h3>
      <p>{t.cards.i18n.desc}</p>
      <div class="visual">
        <div class="langs">
          <div class="lang active"><div class="code">EN</div><span class="lb">English</span></div>
          <div class="lang active"><div class="code">FR</div><span class="lb">Français</span></div>
        </div>
        <div class="langs-soon">
          <span class="lang-ghost">DE</span>
          <span class="lang-ghost">ES</span>
          <span class="lang-ghost">IT</span>
          <span class="lang-ghost">+</span>
          <span class="soon-label">soon</span>
        </div>
      </div>
    </div>

    <!-- Row 4: Hassle (3) + Drawer (3) -->
    <div class="bcard span-3">
      <span class="c-label">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 6l12 12"/><path d="M18 6L6 18"/></svg>
        {t.cards.hassle.label}
      </span>
      <h3>{hassleBefore}<span class="accent">{hassleAfter}</span></h3>
      <p>{t.cards.hassle.desc}</p>
      <div class="visual">
        <div class="goodbye">
          <span class="competitor c1" style="--x: -110px; --y: -24px; --r: -14deg;">pgAdmin</span>
          <span class="competitor c2" style="--x: 85px; --y: -32px; --r: 11deg;">DBeaver</span>
          <span class="competitor c3" style="--x: -45px; --y: 22px; --r: 16deg;">phpMyAdmin</span>
          <span class="competitor c4" style="--x: 75px; --y: 34px; --r: -9deg;">DataGrip</span>
          <span class="competitor c5" style="--x: -115px; --y: 40px; --r: 6deg;">TablePlus</span>
          <span class="competitor c6" style="--x: 105px; --y: -4px; --r: -7deg;">HeidiSQL</span>
          <div class="goodbye-core">
            <img src={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/logo-dblumi-light.svg`} alt="dblumi" />
          </div>
        </div>
      </div>
    </div>

    <div class="bcard span-3">
      <span class="c-label">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/><path d="M9 3v18"/></svg>
        {t.cards.drawer.label}
      </span>
      <h3>{drawerBefore}<span class="accent">{drawerAfter}</span></h3>
      <p>{t.cards.drawer.desc}</p>
      <div class="visual">
        <div class="drawer">
          <div class="deck-card dc1">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
            <span>Query</span>
          </div>
          <div class="deck-card dc2">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
            <span>Share</span>
          </div>
          <div class="deck-card dc3">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
            <span>Explain</span>
          </div>
          <div class="deck-card dc4">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 3H5a2 2 0 0 0-2 2v3"/><path d="M21 8V5a2 2 0 0 0-2-2h-3"/><path d="M3 16v3a2 2 0 0 0 2 2h3"/><path d="M16 21h3a2 2 0 0 0 2-2v-3"/></svg>
            <span>API</span>
          </div>
          <div class="deck-card dc5">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 3 L13.6 10.4 L21 12 L13.6 13.6 L12 21 L10.4 13.6 L3 12 L10.4 10.4 Z"/></svg>
            <span>MCP</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Row 5: Version History (full width) -->
    <div class="bcard span-6 ver-card">
      <div class="ver-text">
        <span class="c-label">
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 12a9 9 0 1 0 3-6.7L3 8"/><polyline points="3 3 3 8 8 8"/><polyline points="12 7 12 12 15 14"/></svg>
          {t.cards.versioning.label}
        </span>
        <h3>{verBefore}<span class="accent">{verAfter}</span></h3>
        <p>{t.cards.versioning.desc}</p>
      </div>
      <div class="ver-visual">
        <div class="ver-mock">
          <div class="ver-hdr">
            <span class="ver-title">Timeline — Products</span>
            <span class="ver-close">×</span>
          </div>
          <div class="ver-body">
            <div class="ver-list">
              <div class="ver-item current">
                <span class="ver-dot"></span>
                <div class="ver-info">
                  <span class="ver-name">Current (editor)</span>
                  <span class="ver-meta">Currently editing</span>
                </div>
              </div>
              <div class="ver-item">
                <span class="ver-check"></span>
                <div class="ver-info">
                  <span class="ver-name">Demo</span>
                  <span class="ver-meta">6 avr. 2026, 01:26</span>
                </div>
              </div>
              <div class="ver-item selected">
                <span class="ver-check on"></span>
                <div class="ver-info">
                  <span class="ver-name">Demo</span>
                  <span class="ver-meta">6 avr. 2026, 01:26</span>
                  <span class="ver-tag">Final version</span>
                </div>
              </div>
              <div class="ver-item">
                <span class="ver-check"></span>
                <div class="ver-info">
                  <span class="ver-name">Demo</span>
                  <span class="ver-meta">6 avr. 2026, 01:25</span>
                </div>
              </div>
            </div>
            <div class="ver-diff">
              <div class="ver-diff-hdr">
                <span class="ver-vs">vs current</span>
                <span class="ver-restore">
                  <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 3-6.7L3 8"/><polyline points="3 3 3 8 8 8"/></svg>
                  Restore
                </span>
              </div>
              <pre class="ver-code"><span class="ln">1</span>  <span class="kw">SELECT</span>
<span class="ln">2</span>    q.id,
<span class="ln">3</span>    q.reference,
<span class="ln">4</span>    c.first_name <span class="op">||</span> <span class="str">' '</span> <span class="op">||</span> c.last_name <span class="kw">AS</span> customer_name,
<span class="ln">5</span>    <span class="fn">COUNT</span>(ql.id) <span class="kw">AS</span> number_of_products,
<span class="ln">6</span>    <span class="fn">SUM</span>(ql.line_total) <span class="kw">AS</span> total_amount
<span class="ln">7</span>  <span class="kw">FROM</span> quotes q
<span class="ln">8</span>  <span class="kw">JOIN</span> customers c <span class="kw">ON</span> q.customer_id = c.id
<span class="ln">9</span>  <span class="kw">ORDER BY</span> q.created_at <span class="kw">DESC</span>
<span class="rem"><span class="ln">10</span>  <span class="kw">LIMIT</span> <span class="num">1000</span>;</span>
<span class="add"><span class="ln">10</span>  <span class="kw">LIMIT</span> <span class="num">100</span>;</span></pre>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Row 6: Mini debug game (full width) -->
    <div class="bcard span-6 game-card dark">
      <div class="game-text">
        <span class="c-label">
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="8" y="6" width="8" height="14" rx="4"/><path d="M19 7l-3 2"/><path d="M5 7l3 2"/><path d="M19 13h-3"/><path d="M8 13H5"/><path d="M19 19l-3-2"/><path d="M5 19l3-2"/><path d="M12 3v3"/></svg>
          {t.cards.game.label}
        </span>
        <h3>{gameBefore}<span class="accent">{gameAfter}</span></h3>
        <p>{t.cards.game.desc}</p>
        <div class="game-score">
          <span class="sc-label">{t.cards.game.score}</span>
          <span class="sc-value" data-score>0</span>
        </div>
      </div>
      <div class="game-arena" data-arena tabindex="0" role="application" aria-label="Mini database pac-man">
        <div class="world" data-world></div>
        <span class="arena-hint">{t.cards.game.hint}</span>
        <div class="arena-overlay" data-overlay>
          <span class="over-title">Game over</span>
          <span class="over-sub">Click to retry</span>
        </div>
      </div>
    </div>

  </div>
</section>

<script>
  // Mini database Pac-Man — arrow keys, collect databases, avoid bugs.
  document.querySelectorAll<HTMLElement>('.game-card').forEach((card) => {
    const arena = card.querySelector<HTMLElement>('[data-arena]');
    const world = card.querySelector<HTMLElement>('[data-world]');
    const scoreEl = card.querySelector<HTMLElement>('[data-score]');
    const overlay = card.querySelector<HTMLElement>('[data-overlay]');
    if (!arena || !world || !scoreEl || !overlay) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    // ── Maze (13×9), '#' = wall, '.' = path ──
    const MAP = [
      '#############',
      '#...........#',
      '#.##.#.#.##.#',
      '#...#...#...#',
      '#.#.#.#.#.#.#',
      '#...........#',
      '#.##.###.##.#',
      '#...........#',
      '#############',
    ];
    const TILE = 22;
    const COLS = MAP[0].length;
    const ROWS = MAP.length;
    const W = COLS * TILE;
    const H = ROWS * TILE;
    world.style.width = W + 'px';
    world.style.height = H + 'px';

    function isWall(tx: number, ty: number) {
      if (ty < 0 || ty >= ROWS || tx < 0 || tx >= COLS) return true;
      return MAP[ty][tx] === '#';
    }

    type Mover = {
      el: HTMLElement;
      tx: number;
      ty: number;
      dx: number;
      dy: number;
      progress: number;     // 0..1 to next tile
      wantDx: number;
      wantDy: number;
      speed: number;        // tiles per frame (at dt=1)
    };

    function mk(cls: string) {
      const el = document.createElement('div');
      el.className = cls;
      world!.appendChild(el);
      return el;
    }

    // Build walls + dots
    const dots: { el: HTMLElement; tx: number; ty: number; taken: boolean }[] = [];

    function buildLevel() {
      world!.querySelectorAll('.wall, .dot').forEach((n) => n.remove());
      dots.length = 0;
      for (let y = 0; y < ROWS; y++) {
        for (let x = 0; x < COLS; x++) {
          if (MAP[y][x] === '#') {
            const w = mk('wall');
            w.style.width = TILE + 'px';
            w.style.height = TILE + 'px';
            w.style.transform = `translate(${x * TILE}px, ${y * TILE}px)`;
          } else {
            // Skip dots at bug spawn positions
            const isSpawn = (x === 6 && y === 5) || (x === 1 && y === 1) || (x === 11 && y === 7);
            if (!isSpawn) {
              const d = mk('dot');
              d.innerHTML = `
                <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <ellipse cx="12" cy="5" rx="9" ry="3"/>
                  <path d="M3 5v14c0 1.7 4 3 9 3s9-1.3 9-3V5"/>
                  <path d="M3 12c0 1.7 4 3 9 3s9-1.3 9-3"/>
                </svg>`;
              d.style.transform = `translate(${x * TILE + (TILE - 12) / 2}px, ${y * TILE + (TILE - 12) / 2}px)`;
              dots.push({ el: d, tx: x, ty: y, taken: false });
            }
          }
        }
      }
    }

    // Player (Pac-dblumi)
    const playerEl = mk('pacman');
    playerEl.innerHTML = `
      <svg viewBox="0 0 32 32" width="18" height="18" aria-hidden="true">
        <defs>
          <clipPath id="pac-mouth"><path d="M16 16 L32 6 L32 26 Z"/></clipPath>
        </defs>
        <circle cx="16" cy="16" r="14" fill="#41cd2a"/>
        <circle cx="16" cy="16" r="14" fill="#0a0a0b" clip-path="url(#pac-mouth)"/>
        <circle cx="16" cy="9" r="2" fill="#0a0a0b"/>
      </svg>`;
    const player: Mover = {
      el: playerEl,
      tx: 1, ty: 1,
      dx: 0, dy: 0,
      progress: 0,
      wantDx: 0, wantDy: 0,
      speed: 0.09,
    };

    // Bugs
    function makeBug(color: string): HTMLElement {
      const b = mk('bug');
      b.innerHTML = `
        <svg viewBox="0 0 32 32" width="18" height="18" aria-hidden="true">
          <ellipse cx="16" cy="17" rx="8" ry="9" fill="${color}"/>
          <circle cx="16" cy="10" r="4.5" fill="${color}"/>
          <path d="M8 15 L3 12" stroke="${color}" stroke-width="1.6" stroke-linecap="round"/>
          <path d="M24 15 L29 12" stroke="${color}" stroke-width="1.6" stroke-linecap="round"/>
          <path d="M8 19 L2 20" stroke="${color}" stroke-width="1.6" stroke-linecap="round"/>
          <path d="M24 19 L30 20" stroke="${color}" stroke-width="1.6" stroke-linecap="round"/>
          <path d="M8 24 L4 27" stroke="${color}" stroke-width="1.6" stroke-linecap="round"/>
          <path d="M24 24 L28 27" stroke="${color}" stroke-width="1.6" stroke-linecap="round"/>
          <circle cx="14" cy="9.5" r="1" fill="#fff"/>
          <circle cx="18" cy="9.5" r="1" fill="#fff"/>
        </svg>`;
      return b;
    }
    const bugSpawns = [
      { tx: 6, ty: 5, color: '#ef4444' },
      { tx: 11, ty: 7, color: '#f59e0b' },
      { tx: 11, ty: 1, color: '#a855f7' },
    ];
    const bugs: Mover[] = bugSpawns.map((s) => ({
      el: makeBug(s.color),
      tx: s.tx, ty: s.ty,
      dx: -1, dy: 0,
      progress: 0,
      wantDx: 0, wantDy: 0,
      speed: 0.07,
    }));

    function placeMover(m: Mover) {
      const px = (m.tx + m.dx * m.progress) * TILE + (TILE - 18) / 2;
      const py = (m.ty + m.dy * m.progress) * TILE + (TILE - 18) / 2;
      m.el.style.transform = `translate(${px}px, ${py}px)`;
    }

    function updateMover(m: Mover, dt: number, isBug: boolean) {
      // If resting, try to start in wanted direction
      if (m.dx === 0 && m.dy === 0) {
        if ((m.wantDx !== 0 || m.wantDy !== 0) && !isWall(m.tx + m.wantDx, m.ty + m.wantDy)) {
          m.dx = m.wantDx;
          m.dy = m.wantDy;
        }
      }
      if (m.dx === 0 && m.dy === 0) return;
      m.progress += m.speed * dt;
      if (m.progress >= 1) {
        m.tx += m.dx;
        m.ty += m.dy;
        m.progress = 0;
        if (isBug) {
          // At each tile, pick a new direction: prefer toward player 60% of the time
          const options: [number, number][] = [];
          const dirs: [number, number][] = [[1, 0], [-1, 0], [0, 1], [0, -1]];
          for (const [dx, dy] of dirs) {
            // Don't reverse unless necessary
            if (dx === -m.dx && dy === -m.dy) continue;
            if (!isWall(m.tx + dx, m.ty + dy)) options.push([dx, dy]);
          }
          if (options.length === 0) {
            // Dead end — reverse
            m.dx = -m.dx;
            m.dy = -m.dy;
          } else if (Math.random() < 0.55) {
            // Chase: pick option minimizing distance to player
            options.sort((a, b) => {
              const da = Math.abs((m.tx + a[0]) - player.tx) + Math.abs((m.ty + a[1]) - player.ty);
              const db = Math.abs((m.tx + b[0]) - player.tx) + Math.abs((m.ty + b[1]) - player.ty);
              return da - db;
            });
            m.dx = options[0][0];
            m.dy = options[0][1];
          } else {
            const pick = options[Math.floor(Math.random() * options.length)];
            m.dx = pick[0];
            m.dy = pick[1];
          }
        } else {
          // Player: apply buffered direction if valid, else continue, else stop
          if ((m.wantDx !== 0 || m.wantDy !== 0) && !isWall(m.tx + m.wantDx, m.ty + m.wantDy)) {
            m.dx = m.wantDx;
            m.dy = m.wantDy;
          } else if (isWall(m.tx + m.dx, m.ty + m.dy)) {
            m.dx = 0;
            m.dy = 0;
          }
        }
      }
      placeMover(m);
    }

    // Face player in movement direction (rotation)
    function facePlayer() {
      let rot = 0;
      if (player.dx === 1) rot = 0;
      else if (player.dx === -1) rot = 180;
      else if (player.dy === -1) rot = -90;
      else if (player.dy === 1) rot = 90;
      const px = (player.tx + player.dx * player.progress) * TILE + (TILE - 18) / 2;
      const py = (player.ty + player.dy * player.progress) * TILE + (TILE - 18) / 2;
      player.el.style.transform = `translate(${px}px, ${py}px) rotate(${rot}deg)`;
    }

    // ── INPUT ──
    function setKey(e: KeyboardEvent) {
      let handled = false;
      if (e.code === 'ArrowLeft') { player.wantDx = -1; player.wantDy = 0; handled = true; }
      else if (e.code === 'ArrowRight') { player.wantDx = 1; player.wantDy = 0; handled = true; }
      else if (e.code === 'ArrowUp') { player.wantDx = 0; player.wantDy = -1; handled = true; }
      else if (e.code === 'ArrowDown') { player.wantDx = 0; player.wantDy = 1; handled = true; }
      if (handled) e.preventDefault();
    }
    arena.addEventListener('keydown', setKey);
    arena.addEventListener('click', () => {
      arena.focus();
      if (dead) respawn();
    });

    // ── STATE ──
    let score = 0;
    let dead = false;
    let lastTs = 0;
    let running = true;

    function respawn() {
      dead = false;
      overlay!.classList.remove('shown');
      player.el.classList.remove('dead');
      player.tx = 1; player.ty = 1;
      player.dx = 0; player.dy = 0;
      player.wantDx = 0; player.wantDy = 0;
      player.progress = 0;
      bugSpawns.forEach((s, i) => {
        bugs[i].tx = s.tx;
        bugs[i].ty = s.ty;
        bugs[i].dx = -1; bugs[i].dy = 0;
        bugs[i].progress = 0;
      });
      score = 0;
      scoreEl!.textContent = '0';
      buildLevel();
      placeAll();
    }

    function die() {
      if (dead) return;
      dead = true;
      player.el.classList.add('dead');
      overlay!.classList.add('shown');
    }

    function placeAll() {
      placeMover(player);
      bugs.forEach(placeMover);
    }

    function tick(ts: number) {
      if (!lastTs) lastTs = ts;
      const dt = Math.min(2.5, (ts - lastTs) / 16.67);
      lastTs = ts;

      if (running && !dead) {
        updateMover(player, dt, false);
        facePlayer();
        bugs.forEach((b) => updateMover(b, dt, true));

        // Collect dot on player tile (when roughly centered)
        if (player.progress < 0.15 || player.progress > 0.85) {
          const cx = player.progress > 0.5 ? player.tx + player.dx : player.tx;
          const cy = player.progress > 0.5 ? player.ty + player.dy : player.ty;
          for (const d of dots) {
            if (!d.taken && d.tx === cx && d.ty === cy) {
              d.taken = true;
              d.el.classList.add('popped');
              setTimeout(() => d.el.remove(), 260);
              score += 1;
              scoreEl!.textContent = String(score);
            }
          }
          if (dots.every((d) => d.taken)) {
            setTimeout(() => { if (!dead) { buildLevel(); placeAll(); } }, 500);
          }
        }

        // Collision with bugs (same tile or within half a tile)
        for (const b of bugs) {
          const ax = player.tx + player.dx * player.progress;
          const ay = player.ty + player.dy * player.progress;
          const bx = b.tx + b.dx * b.progress;
          const by = b.ty + b.dy * b.progress;
          if (Math.abs(ax - bx) < 0.7 && Math.abs(ay - by) < 0.7) {
            die();
            break;
          }
        }
      }

      requestAnimationFrame(tick);
    }

    // Pause when card not visible
    const io = new IntersectionObserver((entries) => {
      for (const e of entries) running = e.isIntersecting;
    });
    io.observe(card);

    // Init
    buildLevel();
    placeAll();
    requestAnimationFrame(tick);
  });
</script>

