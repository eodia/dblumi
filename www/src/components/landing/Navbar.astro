---
// www/src/components/landing/Navbar.astro
import { strings, type Lang } from '../../content/landing-strings';

interface Props {
  lang: Lang;
  stars?: number;
}

const { lang, stars = 2300 } = Astro.props;
const t = strings[lang].nav;

function formatStars(n: number): string {
  if (n >= 1000) return `${(n / 1000).toFixed(1).replace(/\.0$/, '')}k`;
  return String(n);
}

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const langHref = lang === 'en' ? `${base}/fr/` : `${base}/`;
const langLabel = lang === 'en' ? 'FR' : 'EN';
---

<header class="db-nav-wrap">
  <nav class="db-nav" aria-label="Main navigation">
    <a href={lang === 'fr' ? `${base}/fr/` : `${base}/`} class="db-nav-logo" aria-label="dblumi home">
      <img src={`${base}/logo-dblumi-light.svg`} alt="dblumi" />
    </a>
    <div class="db-nav-links">
      <a href={lang === 'fr' ? `${base}/fr/#features` : `${base}/#features`}>{t.features}</a>
      <a href={lang === 'fr' ? `${base}/fr/guides/introduction/` : `${base}/guides/introduction/`}>{t.docs}</a>
      <a href={lang === 'fr' ? `${base}/fr/#pricing` : `${base}/#pricing`}>{t.pricing}</a>
      <a href={lang === 'fr' ? `${base}/fr/blog/` : `${base}/blog/`}>{t.blog}</a>
    </div>
    <a href="https://github.com/eodia/dblumi" class="db-nav-stars" aria-label={`GitHub ${formatStars(stars)} ${t.stars}`}>
      <svg width="12" height="12" viewBox="0 0 24 24" fill="#F59E0B" stroke="#F59E0B" stroke-width="1.5" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
      <span class="num">{formatStars(stars)}</span> {t.stars}
    </a>
    <a href={langHref} class="db-nav-lang" aria-label={langLabel}>{langLabel}</a>
    <a href={lang === 'fr' ? `${base}/fr/guides/installation/` : `${base}/guides/installation/`} class="db-nav-login">{t.login}</a>
    <a href={lang === 'fr' ? `${base}/fr/guides/installation/` : `${base}/guides/installation/`} class="db-nav-cta">{t.cta}</a>
  </nav>
</header>

<style>
  .db-nav-wrap {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    background: rgba(255, 255, 255, 0.72);
    backdrop-filter: blur(14px) saturate(180%);
    -webkit-backdrop-filter: blur(14px) saturate(180%);
    border-bottom: 1px solid rgba(10, 10, 15, 0.06);
  }
  .db-nav {
    display: flex;
    align-items: center;
    gap: 32px;
    padding: 12px 32px;
    max-width: 1400px;
    margin: 0 auto;
  }
  .db-nav-logo {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }
  .db-nav-logo img {
    height: 24px;
    width: auto;
    display: block;
  }
  .db-nav-links { display: flex; gap: 28px; flex: 1; margin-left: 12px; }
  .db-nav-links a {
    font-size: 13px; font-weight: 500;
    color: var(--db-text-soft);
  }
  .db-nav-links a:hover { color: var(--db-text); }
  .db-nav-stars {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 5px 10px;
    border: 1px solid var(--db-border);
    border-radius: 7px;
    font-size: 11.5px; font-weight: 600;
    color: var(--db-text-soft);
  }
  .db-nav-stars .num { color: var(--db-text); }
  .db-nav-lang {
    font-size: 11px; font-weight: 700;
    color: var(--db-muted-fg);
    padding: 4px 8px;
    border-radius: 5px;
    border: 1px solid var(--db-border);
  }
  .db-nav-login { font-size: 13px; font-weight: 600; color: var(--db-text-soft); }
  .db-nav-cta {
    padding: 8px 16px;
    background: var(--db-primary);
    color: #fff;
    border-radius: 8px;
    font-size: 13px; font-weight: 600;
    box-shadow: 0 1px 3px rgba(45, 163, 30, 0.25);
  }
  .db-nav-cta:hover { background: #27901a; }

  @media (max-width: 900px) {
    .db-nav { gap: 16px; padding: 12px 16px; }
    .db-nav-links, .db-nav-stars, .db-nav-login { display: none; }
  }
</style>
