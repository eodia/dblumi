---
// www/src/components/landing/FooterCTA.astro
import { strings, type Lang } from '../../content/landing-strings';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = strings[lang].cta;
const dockerCmd = strings[lang].hero.dockerCmd;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<section class="db-cta">
  <h2>
    <span>{t.headline.line1} <span class="kalam">{t.headline.accent}</span></span>
    <span>{t.headline.line2}</span>
  </h2>
  <p class="sub">{t.sub}</p>
  <div class="btns">
    <a href={lang === 'fr' ? `${base}/fr/guides/installation/` : `${base}/guides/installation/`} class="btn-p">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
      {t.primary}
    </a>
    <a href={lang === 'fr' ? `${base}/fr/demo/` : `${base}/demo/`} class="btn-s">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8"/></svg>
      {t.secondary}
    </a>
  </div>
  <div class="docker-bar">
    <span class="prompt">$</span>
    <code class="cmd">{dockerCmd}</code>
    <button type="button" class="copy" data-cmd={dockerCmd} aria-label="Copy docker command">
      <svg class="ic-copy" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
      <svg class="ic-check" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
    </button>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const copyBtn = document.querySelector<HTMLButtonElement>('.db-cta .docker-bar .copy');
    if (copyBtn) {
      copyBtn.addEventListener('click', async () => {
        const cmd = copyBtn.dataset.cmd ?? '';
        try {
          await navigator.clipboard.writeText(cmd);
          copyBtn.classList.add('copied');
          setTimeout(() => copyBtn.classList.remove('copied'), 1500);
        } catch {
          /* clipboard unavailable */
        }
      });
    }
  });
</script>

<style>
  .db-cta {
    padding: 120px 40px;
    background: #fff;
    border: 1px solid var(--db-border);
    border-radius: 20px;
    text-align: center;
    position: relative;
    overflow: hidden;
    max-width: 1200px;
    margin: 24px auto;
  }
  .db-cta::before {
    content: "";
    position: absolute; inset: 0;
    background: radial-gradient(circle at 50% 100%, rgba(65, 205, 42, 0.09), transparent 60%);
    pointer-events: none;
  }
  .db-cta h2 {
    font-size: 66px; font-weight: 800;
    letter-spacing: -0.03em; line-height: 0.95;
    margin: 0 0 24px;
    color: var(--db-text);
    position: relative;
  }
  .db-cta h2 span { display: block; }
  .db-cta .sub {
    font-size: 17px;
    color: var(--db-muted-fg);
    max-width: 520px;
    margin: 0 auto 36px;
    line-height: 1.55;
    position: relative;
  }
  .db-cta .btns {
    display: flex; gap: 12px;
    justify-content: center;
    position: relative;
  }
  .db-cta .btn-p, .db-cta .btn-s {
    padding: 14px 30px;
    border-radius: 12px;
    font-size: 15px; font-weight: 700;
    display: inline-flex; align-items: center; gap: 8px;
  }
  .db-cta .btn-p {
    background: var(--db-primary);
    color: #fff;
    box-shadow: 0 4px 16px rgba(45, 163, 30, 0.3), 0 0 0 1px rgba(45, 163, 30, 0.2);
  }
  .db-cta .btn-s {
    background: #fff;
    color: var(--db-text);
    border: 1px solid var(--db-border);
  }
  .db-cta .docker-bar {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin: 28px auto 0;
    padding: 8px 8px 8px 14px;
    background: #f7f7f6;
    border: 1px solid #ececeb;
    border-radius: 10px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    color: var(--db-text-soft);
    position: relative;
  }
  .db-cta .docker-bar .prompt { color: #9a9a9a; }
  .db-cta .docker-bar .cmd { font-family: inherit; color: inherit; }
  .db-cta .docker-bar .copy {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    margin-left: 4px;
    border-radius: 7px;
    color: var(--db-muted-fg);
    background: transparent;
    transition: background 0.15s, color 0.15s;
  }
  .db-cta .docker-bar .copy:hover { background: #edecea; color: var(--db-text); }
  .db-cta .docker-bar .copy .ic-check { display: none; color: var(--db-primary); }
  .db-cta .docker-bar .copy.copied .ic-copy { display: none; }
  .db-cta .docker-bar .copy.copied .ic-check { display: inline-block; }

  @media (max-width: 700px) {
    .db-cta { padding: 80px 24px; }
    .db-cta h2 { font-size: 42px; }
    .db-cta .btns { flex-direction: column; }
    .db-cta .docker-bar { font-size: 11px; max-width: 100%; overflow: hidden; }
  }
</style>
