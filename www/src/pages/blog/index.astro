---
import '../../styles/landing.css';
import Navbar from '../../components/landing/Navbar.astro';
import SiteFooter from '../../components/landing/SiteFooter.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Blog — dblumi</title>
    <meta name="description" content="News, updates, and thoughts from the dblumi team." />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
  </head>
  <body>
    <Navbar lang="en" />
    <main class="blog-index">
      <div class="blog-hero">
        <span class="blog-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.376 3.622a1 1 0 0 1 3.002 3.002L7.368 18.635a2 2 0 0 1-.855.506l-2.872.838a.5.5 0 0 1-.62-.62l.838-2.872a2 2 0 0 1 .506-.854z"/></svg>
        </span>
        <h1>Blog</h1>
        <p class="sub">News, releases, and thoughts on databases, tooling, and open source.</p>
      </div>

      <div class="posts">
        {posts.map((post) => {
          const date = new Date(post.data.date);
          const formatted = date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
          return (
            <a href={`${base}/blog/${post.id}/`} class="post-card">
              <div class="post-meta">
                <time datetime={date.toISOString()}>{formatted}</time>
                <span class="author">{post.data.author}</span>
              </div>
              <h2>{post.data.title}</h2>
              <p>{post.data.description}</p>
              <div class="tags">
                {post.data.tags.map((tag: string) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            </a>
          );
        })}
      </div>
    </main>
    <SiteFooter lang="en" />
  </body>
</html>

<style>
  .blog-index {
    max-width: 780px;
    margin: 0 auto;
    padding: 140px 40px 80px;
    font-family: 'Inter', system-ui, sans-serif;
    color: var(--db-text, #0A0A0B);
  }

  .blog-hero {
    text-align: center;
    margin-bottom: 48px;
  }
  .blog-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    border-radius: 16px;
    background:
      radial-gradient(circle at 30% 25%, rgba(65, 205, 42, 0.3), transparent 70%),
      linear-gradient(135deg, #fff 0%, #f5f7f4 100%);
    border: 1px solid rgba(65, 205, 42, 0.28);
    color: var(--db-primary, #2DA31E);
    box-shadow: 0 12px 32px -10px rgba(65, 205, 42, 0.35), 0 0 0 6px rgba(65, 205, 42, 0.05);
    margin-bottom: 18px;
  }
  .blog-hero h1 {
    font-size: 42px;
    font-weight: 800;
    letter-spacing: -0.03em;
    margin: 0 0 8px;
  }
  .blog-hero .sub {
    font-size: 16px;
    color: var(--db-muted-fg, #6B6B76);
    margin: 0;
  }

  .posts {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .post-card {
    display: block;
    padding: 28px 28px 24px;
    border: 1px solid var(--db-border, #E2E2E6);
    border-radius: 16px;
    background: #fff;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
  }
  .post-card:hover {
    border-color: rgba(65, 205, 42, 0.35);
    box-shadow: 0 12px 32px -12px rgba(65, 205, 42, 0.15);
    transform: translateY(-2px);
  }
  .post-card .post-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 12px;
    color: var(--db-muted-fg, #6B6B76);
    margin-bottom: 10px;
  }
  .post-card .author::before {
    content: '·';
    margin-right: 10px;
  }
  .post-card h2 {
    font-size: 22px;
    font-weight: 800;
    letter-spacing: -0.02em;
    margin: 0 0 8px;
    line-height: 1.2;
  }
  .post-card p {
    font-size: 14px;
    color: var(--db-text-soft, #3A3A42);
    margin: 0 0 14px;
    line-height: 1.55;
  }
  .tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }
  .tag {
    font-size: 11px;
    font-weight: 600;
    padding: 3px 9px;
    border-radius: 100px;
    background: var(--db-muted, #F0F0F2);
    color: var(--db-muted-fg, #6B6B76);
  }

  @media (max-width: 700px) {
    .blog-index { padding: 120px 20px 60px; }
    .post-card { padding: 20px; }
    .post-card h2 { font-size: 18px; }
  }
</style>
