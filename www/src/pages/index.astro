---
// dblumi Landing Page — Raycast-inspired design with green theme
import '../styles/landing.css';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>dblumi — The modern SQL client with AI</title>
  <meta name="description" content="The modern SQL client with AI, built for developers. Self-hosted, secure, and team-ready." />
  <link rel="sitemap" href={`${base}/sitemap-index.xml`} />
  <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
</head>
<body>

  <canvas id="starfield" class="dl-starfield"></canvas>

  <a href="#main-content" class="dl-skip-link">Skip to content</a>

  <!-- ═══ Navbar ═══ -->
  <nav class="dl-nav" aria-label="Main navigation">
    <a href={`${base}/`} class="dl-nav-logo" aria-label="dblumi home">
      <img src={`${base}/logo-dblumi.svg`} alt="dblumi" class="dl-nav-logo-img" />
    </a>
    <ul class="dl-nav-links">
      <li><a href={`${base}/guides/introduction/`}>Docs</a></li>
      <li><a href={`${base}/features/sql-editor/`}>Features</a></li>
      <li><a href={`${base}/self-hosting/configuration/`}>Self-hosting</a></li>
    </ul>
    <div class="dl-nav-right">
      <a href={`${base}/fr/`} class="dl-nav-lang" aria-label="Passer en francais">FR</a>
      <a href="https://discord.gg/2uTk5X9B" target="_blank" rel="noopener" class="dl-nav-social" aria-label="Discord">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.095 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.095 2.157 2.42 0 1.333-.947 2.418-2.157 2.418z"/></svg>
      </a>
      <a href="https://github.com/eodia/dblumi" target="_blank" rel="noopener" class="dl-nav-social" aria-label="GitHub">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
      </a>
      <a href={`${base}/guides/installation/`} class="dl-nav-cta">Get started</a>
    </div>
  </nav>

  <main id="main-content">

  <!-- ═══ Hero ═══ -->
  <section class="dl-hero" aria-label="Introduction">
    <div class="dl-hero-badge">
      <span class="pulse"></span>
      <span class="dl-badge-highlight">Open source</span> &middot; Self-hosted &middot; Team-ready
    </div>

    <h1>
      Your SQL,<br />
      <span class="gradient">supercharged with AI</span>
    </h1>

    <p>
      The modern SQL client built for developer teams. Write safer queries with guardrails, get AI-powered suggestions, and share everything with your team.
    </p>

    <div class="dl-docker-copy">
      <span class="dl-docker-prompt">$</span>
      <code class="dl-docker-cmd">docker pull eodia/dblumi:latest</code>
      <button class="dl-docker-btn" data-copy="docker pull eodia/dblumi:latest" aria-label="Copy Docker command">
        <svg class="dl-icon-copy" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
        <svg class="dl-icon-check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
      </button>
    </div>

    <div class="dl-hero-actions">
      <a href={`${base}/guides/installation/`} class="dl-btn-primary">
        <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        Self-host now
      </a>
      <a href={`${base}/app`} class="dl-btn-secondary" target="_blank" rel="noopener">
        <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8"/></svg>
        Live demo
      </a>
    </div>

    <div class="dl-hero-visual">
      <div class="dl-hero-visual-inner">
        <img src={`${base}/images/hero-screenshot.png`} alt="dblumi SQL editor with syntax highlighting, showing a multi-line query with JOIN, WHERE and GROUP BY clauses" />
      </div>
    </div>
  </section>

  <!-- ═══ Feature 1: SQL Editor ═══ -->
  <div class="dl-features">
    <div class="dl-separator"></div>

    <section class="dl-feature">
      <div class="dl-feature-content">
        <span class="dl-feature-label">
          <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
          SQL Editor
        </span>
        <h2>Write SQL with confidence</h2>
        <p>
          A powerful editor with autocompletion, syntax highlighting, and multi-tab support. Built for a blazing fast experience.
        </p>
        <ul class="dl-feature-list">
          <li>4 safety levels — from unrestricted to full guardrails</li>
          <li>Destructive query detection with confirmation prompts</li>
          <li>EXPLAIN plan analysis built-in</li>
          <li>Multi-tab with per-connection contexts</li>
        </ul>
      </div>
      <div class="dl-feature-visual">
        <img src={`${base}/images/feature-editor.png`} alt="dblumi SQL editor with syntax-highlighted query" />
      </div>
    </section>

    <div class="dl-separator"></div>

    <!-- ═══ Feature 2: AI Copilot ═══ -->
    <section class="dl-feature">
      <div class="dl-feature-content">
        <span class="dl-feature-label">
          <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a4 4 0 0 0-4 4v2H6a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V10a2 2 0 0 0-2-2h-2V6a4 4 0 0 0-4-4z"/><circle cx="12" cy="15" r="2"/></svg>
          AI Copilot
        </span>
        <h2>AI that understands your database</h2>
        <p>
          Ask questions in natural language, generate SQL, get explanations and optimizations. The AI knows your schema and adapts to your context.
        </p>
        <ul class="dl-feature-list">
          <li>Anthropic Claude, OpenAI, Azure OpenAI support</li>
          <li>Schema-aware — generates queries that actually work</li>
          <li>Explain, optimize, and debug existing queries</li>
          <li>Bring your own API key — your data stays private</li>
        </ul>
      </div>
      <div class="dl-feature-visual">
        <img src={`${base}/images/feature-ai.png`} alt="dblumi AI Copilot sidebar with saved queries and connections panel" />
      </div>
    </section>

    <div class="dl-separator"></div>

    <!-- ═══ Feature 3: Team collaboration ═══ -->
    <section class="dl-feature">
      <div class="dl-feature-content">
        <span class="dl-feature-label">
          <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          Team Collaboration
        </span>
        <h2>Shared queries, shared knowledge</h2>
        <p>
          Save queries, organize them in folders, and share with your team. Pin the ones that matter. Everyone works from the same playbook.
        </p>
        <ul class="dl-feature-list">
          <li>Folders &amp; pinned queries for fast access</li>
          <li>Share with individuals or groups</li>
          <li>Role-based access — admin, editor, viewer</li>
          <li>SSO with GitHub, Google, or Keycloak</li>
        </ul>
      </div>
      <div class="dl-feature-visual">
        <img src={`${base}/images/feature-team.png`} alt="dblumi SQL editor with saved queries and team sharing" />
      </div>
    </section>

    <div class="dl-separator"></div>

    <!-- ═══ Feature: Version History ═══ -->
    <section class="dl-feature">
      <div class="dl-feature-content">
        <span class="dl-feature-label">
          <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          Version History
        </span>
        <h2>Track every change, restore any version</h2>
        <p>
          Every save creates a version. Browse the full timeline of a query, compare any two versions side by side, and restore a previous version in one click.
        </p>
        <ul class="dl-feature-list">
          <li>Full timeline for every saved query</li>
          <li>Side-by-side diff between any two versions</li>
          <li>One-click restore to roll back instantly</li>
          <li>Custom labels to tag important milestones</li>
        </ul>
      </div>
      <div class="dl-feature-visual">
        <img src={`${base}/images/feature-timeline.png`} alt="dblumi version history timeline with side-by-side diff comparison" />
      </div>
    </section>

    <div class="dl-separator"></div>

    <!-- ═══ Feature: REST API ═══ -->
    <section class="dl-feature">
      <div class="dl-feature-content">
        <span class="dl-feature-label">
          <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 17l6-6-6-6"/><line x1="12" y1="19" x2="20" y2="19"/></svg>
          REST API
        </span>
        <h2>Everything is an API call</h2>
        <p>
          Every action in dblumi is available through a REST API. Automate workflows, integrate with CI/CD pipelines, or build custom tooling — with interactive Swagger documentation built in.
        </p>
        <ul class="dl-feature-list">
          <li>Full REST API for every feature</li>
          <li>Interactive Swagger docs at <code>/api/docs</code></li>
          <li>Automate queries, connections & user management</li>
          <li>OpenAPI spec for code generation in any language</li>
        </ul>
      </div>
      <div class="dl-feature-visual">
        <img src={`${base}/images/feature-swagger.png`} alt="dblumi interactive Swagger API documentation" />
      </div>
    </section>

    <div class="dl-separator"></div>

    <!-- ═══ Feature 4: Schema & ERD ═══ -->
    <section class="dl-feature">
      <div class="dl-feature-content">
        <span class="dl-feature-label">
          <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
          Schema & ERD
        </span>
        <h2>Visualize your data model</h2>
        <p>
          Browse tables, columns, indexes, and constraints at a glance. Generate entity-relationship diagrams to understand your database structure.
        </p>
        <ul class="dl-feature-list">
          <li>Interactive schema browser with search</li>
          <li>Auto-generated ERD diagrams</li>
          <li>Table details — columns, types, constraints</li>
          <li>PostgreSQL, MySQL, Oracle support</li>
        </ul>
      </div>
      <div class="dl-feature-visual">
        <img src={`${base}/images/feature-schema.png`} alt="dblumi database schema browser showing tables list with connections" />
      </div>
    </section>

    <div class="dl-separator"></div>

    <!-- ═══ Feature 5: Security ═══ -->
    <section class="dl-feature">
      <div class="dl-feature-content">
        <span class="dl-feature-label">
          <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          Security First
        </span>
        <h2>Built for production databases</h2>
        <p>
          Self-hosted by design. Your credentials never leave your infrastructure. Four levels of query guardrails protect against accidental data loss.
        </p>
        <ul class="dl-feature-list">
          <li>100% self-hosted — nothing in the cloud</li>
          <li>AES-256 encrypted credentials at rest</li>
          <li>4 guardrail levels: none &rarr; strict</li>
          <li>RBAC + SSO for enterprise teams</li>
        </ul>
      </div>
      <div class="dl-feature-visual">
        <img src={`${base}/images/feature-security.png`} alt="dblumi database browser with connection management and table structure" />
      </div>
    </section>
  </div>

  <!-- ═══ Stats ═══ -->
  <div class="dl-separator" style="max-width: 1200px; margin: 0 auto;"></div>

  <section class="dl-stats">
    <div>
      <div class="dl-stat-value">3</div>
      <div class="dl-stat-label">Database engines</div>
    </div>
    <div>
      <div class="dl-stat-value">4</div>
      <div class="dl-stat-label">Guardrail levels</div>
    </div>
    <div>
      <div class="dl-stat-value">3</div>
      <div class="dl-stat-label">AI providers</div>
    </div>
    <div>
      <div class="dl-stat-value">100%</div>
      <div class="dl-stat-label">Self-hosted</div>
    </div>
  </section>

  <!-- ═══ Planet + Pricing ═══ -->
  <div class="dl-planet-wrapper"></div>

  <section class="dl-pricing">
    <div class="dl-pricing-header">
      <div class="dl-pricing-label">Pricing</div>
      <h2>Open source, all features included.</h2>
      <p>dblumi is free and open source with every feature. Professional support available for enterprises.</p>
    </div>

    <div class="dl-pricing-grid dl-pricing-grid-2">
      <!-- Open Source -->
      <div class="dl-pricing-card featured">
        <div class="dl-pricing-name">Open Source</div>
        <div class="dl-pricing-desc">All features, forever free. Self-host on your infrastructure.</div>
        <div class="dl-pricing-price">
          <span class="dl-pricing-amount">Free</span>
          <span class="dl-pricing-period">/ AGPL-3.0</span>
        </div>
        <a href={`${base}/guides/installation/`} class="dl-pricing-cta dl-pricing-cta-primary">
          <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          Self-host now
        </a>
        <ul class="dl-pricing-features">
          <li><span class="dl-pricing-check"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg></span> Unlimited connections & users</li>
          <li><span class="dl-pricing-check"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg></span> SQL editor with 4 guardrail levels</li>
          <li><span class="dl-pricing-check"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg></span> AI Copilot (Claude, OpenAI, Azure)</li>
          <li><span class="dl-pricing-check"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg></span> Saved queries, folders & sharing</li>
          <li><span class="dl-pricing-check"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg></span> Schema browser & ERD</li>
          <li><span class="dl-pricing-check"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg></span> Groups & RBAC</li>
          <li><span class="dl-pricing-check"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg></span> SSO (GitHub, Google, Keycloak)</li>
          <li><span class="dl-pricing-check"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg></span> AES-256 encrypted credentials</li>
          <li><span class="dl-pricing-check"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg></span> Community support</li>
        </ul>
      </div>

      <!-- Enterprise Support -->
      <div class="dl-pricing-card">
        <div class="dl-pricing-name">Enterprise Support</div>
        <div class="dl-pricing-desc">For organizations that need professional support and guarantees.</div>
        <div class="dl-pricing-price">
          <span class="dl-pricing-amount">Custom</span>
        </div>
        <a href="mailto:dblumi@eodia.com" class="dl-pricing-cta dl-pricing-cta-default">Contact us</a>
        <ul class="dl-pricing-features">
          <li><span class="dl-pricing-check"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg></span> Everything in Open Source</li>
          <li><span class="dl-pricing-check"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg></span> Dedicated support & SLA</li>
          <li><span class="dl-pricing-check"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg></span> Deployment & migration help</li>
          <li><span class="dl-pricing-check"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg></span> Custom integrations</li>
          <li><span class="dl-pricing-check"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg></span> Security audit & compliance</li>
          <li><span class="dl-pricing-check"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg></span> Training for your team</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- ═══ FAQ ═══ -->
  <div class="dl-separator" style="max-width: 1200px; margin: 0 auto;"></div>

  <section class="dl-faq">
    <div class="dl-faq-header">
      <div class="dl-pricing-label">FAQ</div>
      <h2>Frequently asked questions</h2>
    </div>
    <div class="dl-faq-grid">
      <details class="dl-faq-item">
        <summary>Is dblumi really free?</summary>
        <p>Yes. dblumi is open source under AGPL-3.0 with every feature included. No premium tier, no feature gates. Enterprise support is available as a paid option.</p>
      </details>
      <details class="dl-faq-item">
        <summary>Which databases are supported?</summary>
        <p>PostgreSQL, MySQL, and Oracle. You can connect to multiple databases simultaneously, each with its own environment tag and access controls.</p>
      </details>
      <details class="dl-faq-item">
        <summary>Where is my data stored?</summary>
        <p>Everything stays on your infrastructure. dblumi is 100% self-hosted &mdash; database credentials are encrypted with AES-256 and never leave your server.</p>
      </details>
      <details class="dl-faq-item">
        <summary>How does the AI copilot work?</summary>
        <p>The copilot uses your own API key (Anthropic Claude, OpenAI, or Azure OpenAI). It reads your schema to generate accurate queries. Your data is never stored or used for training.</p>
      </details>
      <details class="dl-faq-item">
        <summary>Can I use dblumi with my team?</summary>
        <p>Absolutely. Share connections and saved queries with specific users or groups. Role-based access control (admin, editor, viewer) keeps everything organized.</p>
      </details>
      <details class="dl-faq-item">
        <summary>How do I deploy dblumi?</summary>
        <p>One <code>docker compose up -d</code> command. The app runs on a single container with an embedded SQLite database for its own state. No external dependencies required.</p>
      </details>
    </div>
  </section>

  <!-- ═══ CTA ═══ -->
  <div class="dl-separator" style="max-width: 1200px; margin: 0 auto;"></div>

  <section class="dl-cta-section">
    <h2>Ready to <span class="gradient">take control</span>?</h2>
    <p>Deploy dblumi in minutes. One Docker command, full control over your data.</p>

    <div class="dl-docker-copy">
      <span class="dl-docker-prompt">$</span>
      <code class="dl-docker-cmd">docker pull eodia/dblumi:latest</code>
      <button class="dl-docker-btn" data-copy="docker pull eodia/dblumi:latest" aria-label="Copy Docker command">
        <svg class="dl-icon-copy" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
        <svg class="dl-icon-check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
      </button>
