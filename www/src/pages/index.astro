---
// www/src/pages/index.astro
import '../styles/landing.css';
import Navbar from '../components/landing/Navbar.astro';
import Hero from '../components/landing/Hero.astro';
import TrustBar from '../components/landing/TrustBar.astro';
import FeatureWrite from '../components/landing/FeatureWrite.astro';
import FeatureAsk from '../components/landing/FeatureAsk.astro';
import FeatureCollab from '../components/landing/FeatureCollab.astro';
import BentoSection from '../components/landing/BentoSection.astro';
import Pricing from '../components/landing/Pricing.astro';
import FAQ from '../components/landing/FAQ.astro';
import FooterCTA from '../components/landing/FooterCTA.astro';
import SiteFooter from '../components/landing/SiteFooter.astro';

// Fetch GitHub stars at build time. Falls back to 2300 on error.
let githubStars = 2300;
try {
  const res = await fetch('https://api.github.com/repos/eodia/dblumi');
  if (res.ok) {
    const data = await res.json();
    if (typeof data.stargazers_count === 'number') {
      githubStars = data.stargazers_count;
    }
  }
} catch {
  /* use fallback */
}

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>dblumi — The modern SQL client with AI copilot</title>
    <meta name="description" content="The open source SQL client with AI copilot. Self-hosted, team-ready, AGPL-3.0. Query, explore, ship — without friction." />
    <meta property="og:title" content="dblumi — The modern SQL client with AI copilot" />
    <meta property="og:description" content="Query, explore, ship — without friction. Self-hosted, AGPL-3.0." />
    <meta property="og:type" content="website" />
    <link rel="sitemap" href={`${base}/sitemap-index.xml`} />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
  </head>
  <body>
    <Navbar lang="en" stars={githubStars} />
    <Hero lang="en" />
    <main class="landing-page">
      <TrustBar lang="en" stars={githubStars} />
      <div id="features">
        <FeatureWrite lang="en" />
        <FeatureAsk lang="en" />
        <FeatureCollab lang="en" />
      </div>
      <BentoSection lang="en" />
      <Pricing lang="en" />
      <FAQ lang="en" />
      <FooterCTA lang="en" />
    </main>
    <SiteFooter lang="en" />
  </body>
</html>
