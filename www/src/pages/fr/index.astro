---
// www/src/pages/fr/index.astro
import '../../styles/landing.css';
import Navbar from '../../components/landing/Navbar.astro';
import Hero from '../../components/landing/Hero.astro';
import FeatureWrite from '../../components/landing/FeatureWrite.astro';
import FeatureAsk from '../../components/landing/FeatureAsk.astro';
import FeatureCollab from '../../components/landing/FeatureCollab.astro';
import BentoSection from '../../components/landing/BentoSection.astro';
import Pricing from '../../components/landing/Pricing.astro';
import FAQ from '../../components/landing/FAQ.astro';
import FooterCTA from '../../components/landing/FooterCTA.astro';
import SiteFooter from '../../components/landing/SiteFooter.astro';

let githubStars = 2300;
try {
  const res = await fetch('https://api.github.com/repos/eodia/dblumi');
  if (res.ok) {
    const data = await res.json();
    if (typeof data.stargazers_count === 'number') githubStars = data.stargazers_count;
  }
} catch { /* fallback */ }

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>dblumi — Le client SQL moderne avec copilot IA</title>
    <meta name="description" content="Le client SQL open source avec copilot IA. Auto-hébergé, prêt pour les équipes, AGPL-3.0. Query, explore, ship — sans friction." />
    <meta property="og:title" content="dblumi — Le client SQL moderne avec copilot IA" />
    <meta property="og:description" content="Query, explore, ship — sans friction. Auto-hébergé, AGPL-3.0." />
    <meta property="og:type" content="website" />
    <link rel="sitemap" href={`${base}/sitemap-index.xml`} />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
  </head>
  <body>
    <!-- TODO: re-enable stars when repo has some: stars={githubStars} -->
    <Navbar lang="fr" />
    <Hero lang="fr" />
    <main class="landing-page">
      <div id="features">
        <FeatureWrite lang="fr" />
        <FeatureAsk lang="fr" />
        <FeatureCollab lang="fr" />
      </div>
      <BentoSection lang="fr" />
      <Pricing lang="fr" />
      <FAQ lang="fr" />
      <FooterCTA lang="fr" />
    </main>
    <SiteFooter lang="fr" />
  </body>
</html>
